@page
@using swas.Areas.Identity.Pages.Account
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    //Layout = null;
    Layout = "~/Views/Shared/_Layoutreg.cshtml";
}
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>Login</title>

  
    <!--plugins-->
  
    <link href="~/css/login.css" rel="stylesheet" />
    <script src="~/developerjs/login.js"></script>
    

</head>

<body class="bg-primary">
    <div id="layoutAuthentication">
        <div id="layoutAuthentication_content">
            <main>
                <div class="container aj">
                    <div class="row justify-content-center">
                        <div class="d-flex1">

                            <div class="col-sm-12">

                                <div class="card shadow-lg border-0 rounded-lg">
                                    <div class="card-header">
                                        <h6 class="loginheading text-center">Login</h6>
                                    </div>
                                    <div class="card-body">
                                        <form id="account" method="post" class="form-group row g-3">

                                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                            <div class="col-12">
                                                <label asp-for="Input.UserName" class="form-label">Username</label>
                                                <div class="input-group">
                                                    <input asp-for="Input.UserName" class="form-control" maxlength="35" aria-required="true" placeholder="Username" />
                                                    <span asp-validation-for="Input.UserName" class="text-danger"></span>
                                                </div>
                                            </div>

                                            <div class="col-12">
                                                <label asp-for="Input.Password" class="inputChoosePassword form-label">Enter Password</label>
                                                <div class="input-group" id="show_hide_password">
                                                    <input asp-for="Input.Password" type="password" class="form-control" value="Dte@123" autocomplete="current-password" aria-required="true" id="myInput" placeholder="Password" />
                                                    <a href="javascript:;" class="input-group-text bg-transparent">
                                                        <input type="checkbox" onclick="myFunction()">
                                                    </a>
                                                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                                                </div>
                                            </div>

                                            <div class="col-12">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="flexSwitchCheckChecked" checked>
                                                    <label class="form-check-label" for="flexSwitchCheckChecked">Remember Me</label>
                                                </div>
                                            </div>

                                            <div class="col-12">
                                                <div class="d-grid">
                                                    <button id="login-submit" type="submit" class="btn btn-primary"><i class="bx bxs-lock-open"></i>Sign in</button>
                                                </div>
                                            </div>

                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>

        <footer class="footer1 paw-footer-fixed">
            <div class="footer-text">
                Copyright &copy; Developed by ASDC, DGIS
            </div>
        </footer>
    </div>

    <script src="~/js/jquery.min.js"></script>
    <script src="~/js/sweetalert2.all.min.js"></script>

    
    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>


