@model swas.DAL.Models.tbl_mStages

@{
    ViewData["Title"] = "Edit Stage";

}
<link href="~/css/editstage.css" rel="stylesheet" />
<div>
    <div class="container mt-1">
        <div class="row justify-content-center">
            <div class="container-fluid">
                <form asp-action="EditFrom" asp-controller="Stages" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="StagesId" />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Stages" class="form-label">
                                    <b>Stage Name</b>
                                    <span class="required-indicator">*</span>
                                </label>
                                <input asp-for="Stages" class="form-control" required onkeyup="ValInData(this)" value="@Model.Stages" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="text-center button-container">
                            <button type="submit" data-id="@Model.StagesId" data-name="@Model.Stages" class="btn btn-primary btnupdate">Update</button>
                            <button class="btn btn-secondary" type="button">
                                <a href="/Stages/Create" class="close-link">Close</a>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {

    <partial name="_ValidationScriptsPartial" />
}




<script src="~/developerjs/Status.js"></script>