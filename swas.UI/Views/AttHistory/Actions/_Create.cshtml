@model swas.DAL.Models.tbl_mActions

@{
    ViewData["Title"] = "Create New Action";
}
<head>

    <link  href="~/css/Atthitory_Create.css"/>

</head>
<div class="container mt-1">
    <div class="row justify-content-center">
        <div class="container-fluid">
            <form asp-action="Create" method="post" class="needs-validation" novalidate>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Actions"><b>Action Name</b> <span class="required-indicator">*</span></label>
                            <input asp-for="Actions" class="form-control" required onkeyup="ValInData(this)" />
                            <div class="invalid-feedback">Please provide an action name.</div>
                            <span asp-validation-for="Actions" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="text-center custom-buttons">
                            <button type="submit" class="btn btn-primary">Create</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>



<script src="~/DeveloperJs/Actions.js"></script>