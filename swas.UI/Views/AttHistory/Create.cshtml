@using swas.DAL.Models
@model List<tbl_AttHistory>

@{
    ViewBag.Title = "Attachment History List";
}

<h2>Attachment History List</h2>

<div class="wrapper">
    <div class="add-new-btn">
        <button id="addNewButton">Add New</button>
    </div>

    <table id="attachmentHistoryTable" class="display">
        <thead>
            <tr>
                <th>Attachment ID</th>
                <th>PSM ID</th>
                <th>Attachment Path</th>
                <th>Action ID</th>
                <th>Timestamp</th>
                <th>Is Deleted</th>
                <th>Is Active</th>
                <th>Edit/Delete By</th>
                <th>Edit/Delete Date</th>
                <th>Updated By User ID</th>
                <th>Date of Update</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var attachment in Model)
            {
                <tr>
                    <td>@attachment.AttId</td>
                    <td>@attachment.PsmId</td>
                    <td>@attachment.AttPath</td>
                    <td>@attachment.ActionId</td>
                    <td>@attachment.TimeStamp?.ToString("dd-MM-yyyy HH:mm:ss")</td>
                    <td>@attachment.IsDeleted</td>
                    <td>@attachment.IsActive</td>
                    <td>@attachment.EditDeleteBy</td>
                    <td>@attachment.EditDeleteDate?.ToString("dd-MM-yyyy")</td>
                    <td>@attachment.UpdatedByUserId</td>
                    <td>@attachment.DateTimeOfUpdate?.ToString("dd-MM-yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

