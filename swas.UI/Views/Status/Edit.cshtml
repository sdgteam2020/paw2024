

@model swas.DAL.Models.tbl_mStatus

@{
    ViewData["Title"] = "Edit Sub Stage";

}
<link href="~/css/status_edit.css" rel="stylesheet" />
<div>
    <div class="container mt-1">
        <div class="row justify-content-center">
            <div class="container-fluid">
                <form asp-action="Edit" asp-controller="Stauts" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="StatusId" />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Status" class="form-label">
                                    <b>Stage Name</b>
                                    <span class="required-indicator">*</span>
                                </label>
                                <input asp-for="Status" class="form-control" required onkeyup="ValInData(this)" value="@Model.Status" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="text-center form-buttons">
                            <button type="submit" data-id="@Model.StatusId" data-name="@Model.Status" class="btn btn-primary btnupdate">Update</button>
                            <button class="btn btn-secondary" type="button">
                                <a href="/Status/Create" class="close-link">Close</a>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



@section Scripts {

    <partial name="_ValidationScriptsPartial" />
}




    <script src="~/developerjs/Status.js"></script>