
@model swas.DAL.Models.tbl_mStatus
@using swas.BAL.DTO
@using swas.BAL.Helpers
@using Microsoft.AspNetCore.Identity

@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Create New Stage";

    Login Logins = SessionHelper.GetObjectFromJson<Login>(HttpContextAccessor.HttpContext.Session, "User");

}
<link href="~/css/_createstatus.css" rel="stylesheet" />
<div>
    <div class="container mt-1">
        <div class="row justify-content-center">
            <div class="container-fluid">
                <form asp-action="CreateStatus" method="post" class="needs-validation" novalidate onsubmit="return validateForm()">
                        @Html.AntiForgeryToken()
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Status" class="form-label">
                                    <b>Sub Stage Name</b>
                                    <span class="required-indicator">*</span>
                                </label>
                                <input asp-for="Status" class="form-control" required onkeyup="ValInData(this)" />
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="text-center form-buttons">
                                <button type="submit" class="btn btn-primary">Create</button>
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {

    <partial name="_ValidationScriptsPartial" />
}

<script src="~/developerjs/_createstatus.js"></script>