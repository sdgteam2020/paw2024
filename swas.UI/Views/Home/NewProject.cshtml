<div class="modal fade bd-example-modal-xl" id="WhiteListedProjectDetail" tabindex="-1" role="dialog" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Whitelisted Projects</h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body WhitelistedTablesss">
               
                    <table id="WhitelistedTable" class="table  table-striped table-bordered datatablefordownload" style="overflow: scroll;">
                        <!-- Table header -->

                        <thead style="position: sticky;top:-18px">
                        @if (Logins?.unitid == 1)
                            {
                                <button class="btn btn-primary" id="AddWhite_proj">Add WhiteList</button>
                            }

                            <tr>

                                <th class="text-center s-no-column" style="width:1%">S.No</th>
                                <th class="text-nowrap text-center" style="width:6%">Name of Sw Appl</th>
                                <th class="text-nowrap text-center" style="width:12% !important">Hosted On</th>

                                <th class="text-nowrap text-center" style="width:4% !important">Appt</th>
                                <th class="text-nowrap text-center" style="width:4% !important">Sponsor</th>
                                <th class="text-nowrap text-center" style="width:2% !important">Tele No</th>
                                <th class="text-nowrap text-center" style="width:2% !important">Dt of ACG Clearance</th>
                                <th class="text-nowrap text-center" style="width:15% !important">Cert No</th>
                                <th class="text-nowrap text-center" style="width:4% !important">Valid Upto</th>
                                <th class="text-nowrap text-center" style="width:4% !important">Remarks</th>

                                @if (Logins?.unitid == 1)
                                {
                                    <th class="text-nowrap text-center" style="width:4% !important">Action</th>
                                }
                            </tr>
                        </thead>
                        <tbody>

                            @if (WhiteListed != null)
                            {
                                int count = 1;
                                int headerid = 0;
                                @foreach (var unitx in WhiteListed)
                                {
                                    <tr>
                                        <td class="s-no-column">@count</td>
                                        @* <td class="col-width16">@unitx.ProjName</td> *@









                                    <td class="RefLetter-container" style="width:6%">
                                        <span class="noExport">  @(string.IsNullOrEmpty(@unitx.ProjName) ? "" : (@unitx.ProjName.Length > 10) ? @unitx.ProjName.Substring(0, 10) + "...." : @unitx.ProjName)</span>
                                          
                                           
                                                <div class="RefLetter">
                                                    @unitx.ProjName
                                                </div>

                                            
                                        </td>
                                        <td class="col-width9">@unitx.HostedOn</td>

                                        <td>@unitx.Appt</td>
                                        <td>@unitx.Fmn</td>
                                        <td class="col-width6">@unitx.ContactNo</td>
                                        <td class="col-width6">@(unitx.Clearence != null ? unitx.Clearence.ToString("dd-MM-yyyy") : "")</td>
                                        @{
                                            DateTime? clearenceDate = unitx.Clearence;
                                            DateTime? afterThreeYears = null;

                                            if (clearenceDate.HasValue)
                                            {
                                                afterThreeYears = clearenceDate.Value.AddYears(3);
                                            }
                                        }


                                        @*  <td>
                                @unitx.CertNo
                                </td> *@
                                        <td>


                                            @unitx.CertNo

                                        </td>

                                        <td class="col-width6">
                                            @(afterThreeYears.HasValue ? afterThreeYears.Value.ToString("dd-MM-yyyy") : "")
                                        </td>
                                        @*  <td>@unitx.Remarks</td> *@
                                        <td class="RefLetter-container">
                                        <span class="noExport">@(string.IsNullOrEmpty(@unitx.Remarks) ? "" : (@unitx.Remarks.Length > 10) ? @unitx.Remarks.Substring(0, 10) + "...." : @unitx.Remarks)</span>
                                            
                                            @if (!string.IsNullOrEmpty(@unitx.Remarks) && (@unitx.Remarks.Length > 10))
                                            {
                                                <div class="RefLetter">
                                                    @unitx.Remarks
                                                </div>

                                            }
                                        </td>
                                        @if (Logins?.unitid == 1)
                                        {
                                            <td>
                                                <center>
                                                    <a class="EditWhiteListedProj" href="#" data-id="@unitx.Id">
                                                        <div>
                                                            <img src="/assets/images/icons/edit.png" alt="Icon" style="width: 35px; height: 30px; margin-right: 0px;">
                                                        </div>
                                                    </a>
                                                </center>
                                            </td>
                                        }
                                    </tr>

                                    count = count + 1;
                                    @* headerid = @unitx.HeaderID; *@
                                }
                            }

                        </tbody>
                    </table>

                
              

            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="EditWhiteListedProjectModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="editWhiteListedForm">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Whitelisted Project</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">

                    <input type="hidden" id="edit_Id" name="Id" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="edit_ProjName" class="form-label">Name of Sw Appl</label>
                            <input type="text" id="edit_ProjName" name="ProjName" class="form-control" readonly />
                        </div>
                        <div class="col-md-6">
                            <label for="edit_HostedOn" class="form-label">Hosted On</label>
                            <select id="edit_HostedOn" name="mHostTypeId" class="form-select">
                                <option value="">-- Select Hosted On --</option>
                                <option value="1">ADN</option>
                                <option value="2">LAN</option>
                                <option value="3">Internet</option>
                                <option value="4">Standalone</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="edit_Appt" class="form-label">Appt</label>
                            <input type="text" id="edit_Appt" name="Appt" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="edit_Sponser" class="form-label">Sponsor</label>
                         @*    <input type="text" id="edit_Sponser" name="Fmn" class="form-control" /> *@
                            <select class="form-control" id="edit_Sponser" name="Fmn" data-mdb-select-init>
                                <option value="">-- Select Sponsor --</option>
                                @if (ViewBag.Units != null)
                                {
                                    foreach (var unit in ViewBag.Units)
                                    {
                                        <option value="@unit.UnitName">@unit.UnitName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="edit_TelNo" class="form-label">Tele No</label>
                            <input type="text" id="edit_TelNo" name="ContactNo" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="edit_Clearance" class="form-label">Clearance</label>
                            <input type="date" id="edit_Clearance" name="Clearence" class="form-control" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="edit_Cert" class="form-label">Cert</label>
                            <input type="text" id="edit_Cert" name="CertNo" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label for="edit_ValidUpto" class="form-label">DDGIT WL DT</label>
                            <input type="date" id="edit_ValidUpto" name="ValidUpto" class="form-control" />
                        </div>

                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="edit_Remarks" class="form-label">Remarks</label>
                            <textarea id="edit_Remarks" name="Remarks" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>
            </form>
        </div>
