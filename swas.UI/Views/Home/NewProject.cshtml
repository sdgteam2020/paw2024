                                </div>

                                <div class="login" style="margin-top:1rem;">
                                    <h1 class="login-header">Login</h1>
                                </div>

                                <div class="col-12 shadow-lg mb-2 bg-white rounded" style="margin-left: 7.5rem;width: 29rem;">
                                    <div id="flush-collapseOne" aria-labelledby="flush-headingOne" data-bs-parent="#accordionFlushExample">
                                        <div class="card-body">
                                            <div class="">
                                                @Html.AntiForgeryToken()
                                                <div class="row">
                                                    <div class="col-md-4 col-12">
                                                        <div class="form-group">
                                                            <label for="UserId" class="control-label">Domain ID</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-8 col-12">
                                                        <div class="form-group">
                                                            <input type="text" id="UserId" name="UserId" class="form-control readonly" value="@username" readonly required />
                                                            @Html.ValidationMessageFor(model => model.UserId, "", new { @class = "text-danger" })
                                                        </div>
                                                    </div>

                                                    <div class="col-md-4 col-12">
                                                        <div class="form-group">
                                                            <label for="RoleId" class="control-label">Role</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-8 col-12">
                                                        <div class="form-group">
                                                            <input type="text" id="RoleId" name="RoleId" class="form-control readonly" value="@role" readonly required onkeyup="ValInData(this)" />
                                                        </div>
                                                    </div>

                                                    <div class="col-md-12 col-12 text-center">
                                                        <div class="form-group">
                                                            <button class="btn btn-primary btn-block" style="background-color: @(ViewBag.ProcessButtonColor);" id="ProcessId" onclick="ButtonClick()">
                                                                @(ButtonText)
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gradient-custom-2">
                        <div class="text-white px-3 py-4  mx-md-4">
                            <div class="cards-list">
                                <div class="row box card-r">
                                    <div class="col-md-4" id="PolicyWhiteList">
                                        <div class="card1 hover-point">
                                            <div class="card_title title-white" style="text-align: center; color: black;">
                                                @* <p class="font-d">Policy on Whitelisting</p> *@
                                                <p class="font-d">Policies on WhiteListing</p>
                                            </div>
                                            <div class="card_image"><img src="~/assets/images/Policy1.png" class="images" /></div>
                                        </div>

                                    </div>
                                    <div class="col-md-4" id="whitelistCard">
                                        <div class="card1 hover-point">
                                            <div class="card_title title-white" style="text-align: center; color: black;">
                                                @* <p class="font-d">Projs Under Process</p> *@
                                                <p class="font-d">Real Time Proj <br />Status</p>
                                            </div>
                                            <div class="card_image"><img src="~/assets/images/projectunder.png" class="images" /></div>

                                        </div>

                                    </div>

                                    <div class="col-md-4" id="WhiteListedProject">
                                        
                                        <div class="card1 hover-point">
                                            <div class="card_title title-white" style="text-align: center; color: black;">
                                                @* <p class="font-d">WhiteListed Projects</p> *@
                                                <p class="font-d">View WhiteListed Projs</p>
                                            </div>
                                            <div class="card_image"><img src="~/assets/images/Completed1.png" class="images" /></div>
                                           
                                        </div>
                                    </div>
                                   
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

