@using swas.BAL.DTO;
@using swas.DAL.Models
@using swas.BAL.Helpers
@model UnitValidate
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Software Whitelisting Autoation Software";
    int sno = 0;
    Layout = "";

    var username = ViewBag.LoggedInUserName;
    var ip = ViewBag.ipadd;
    var flag = ViewBag.flag;

    var ButtonText = ViewBag.ButtonText;

    var role = ViewBag.userRole;
    var newproject = ViewBag.RecentAction;
    var WhiteListed = ViewBag.WhiteListed;
    var Holdproj = ViewBag.HoldProj;
    var corse = ViewBag.Courses;

    var PdfWhiteList = ViewBag.PdfWhiteListed;
    var stage = ViewBag.RFPProj;

    Login Logins = SessionHelper.GetObjectFromJson<Login>(HttpContextAccessor.HttpContext.Session, "User");

    // ✅ CSP: no inline style allowed -> map ProcessButtonColor to a class (extend as needed)
    string processBtnClass = "paw-process-btn";
    string processColor = (ViewBag.ProcessButtonColor as string) ?? "";
    var c = processColor.ToLowerInvariant();

    if (c.Contains("green") || c.Contains("#28a745") || c.Contains("success"))
        processBtnClass = "paw-process-btn paw-process-btn-success";
    else if (c.Contains("red") || c.Contains("#dc3545") || c.Contains("danger"))
        processBtnClass = "paw-process-btn paw-process-btn-danger";
    else if (c.Contains("yellow") || c.Contains("#ffc107") || c.Contains("warning") || c.Contains("orange"))
        processBtnClass = "paw-process-btn paw-process-btn-warning";
    else
        processBtnClass = "paw-process-btn paw-process-btn-primary";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">

    <link href="~/css/newpage.css" rel="stylesheet" />
    <link href="~/css/sweetalert2.min.css" rel="stylesheet">
    <link href="~/css/NewProject.css" rel="stylesheet" />
    <link href="~/assets/css/tooltip.css" rel="stylesheet" />

    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/select2.min.css" rel="stylesheet" />
    <link href="~/assets/css/font-awesome/fonts/font-awesome.min.css" rel="stylesheet" />

    <!-- ✅ CSP-safe extracted CSS (from inline <style> + style="...") -->
    <link href="~/css/paw-whitelist-page.css" rel="stylesheet" asp-append-version="true" />

    <script src="~/assets/js/jquery.min.js"></script>
    <script src="~/assets/js/bootstrap.min.js"></script>

    <script src="~/assets/js/main.js"></script>

    <script src="~/assets/dataTable/js/jquery.dataTables.min.js"></script>
    <script src="~/assets/dataTable/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/assets/dataTable/js/dataTables.buttons.min.js"></script>
    <script src="~/assets/dataTable/js/buttons.bootstrap4.min.js"></script>
    <script src="~/assets/dataTable/js/jszip.min.js"></script>
    <script src="~/assets/dataTable/js/vfs_fonts.js"></script>
    <script src="~/assets/dataTable/js/buttons.html5.min.js"></script>
    <script src="~/assets/dataTable/js/buttons.print.min.js"></script>
    <script src="~/assets/dataTable/js/buttons.colVis.min.js"></script>
    <script src="~/assets/dataTable/js/dataTables.responsive.min.js"></script>
    <script src="~/assets/dataTable/js/responsive.bootstrap4.min.js"></script>

    <script src="~/js/sweetalert2.all.min.js"></script>
    <script src="~/DeveloperJs/ddlSanal.js"></script>
    <script src="~/assets/datatable/js/select2.min.js"></script>
</head>

<body
    data-flag="@flag"
    data-buttontext="@ButtonText"
    data-username="@username"
    data-ip="@ip">

    <header class="top-headers paw-top-headers">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-2 col-md-1">
                    <img src="~/assets/images/logo2.png" class="dgislogo1 paw-logo-left" alt="Left Image" />
                </div>
                <div class="col-8 col-md-10 text-center">
                    <p class="headertext paw-headertext-center">Portal for Appl Whitelisting (PAW)</p>
                </div>
                <div class="col-2 col-md-1 text-end">
                    <img src="~/assets/images/logo2.png" class="dgislogo1 paw-logo-right" alt="Right Image" />
                </div>
            </div>
        </div>
    </header>

    <div class="wrapper paw-wrapper-hidden">
        <div class="page-content"></div>
    </div>

    <!-- ===================== Modals ===================== -->

    <div class="modal fade bd-example-modal-xl" id="ProjectPolicyModel" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Policy on Whitelisting</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered datatablefordownload">
                            <thead>
                                <tr>
                                    <th class="text-nowrap text-center">Policy on Whitelisting of SW</th>
                                    <th class="text-nowrap text-center">Whitelisted Software/Appls Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        @if (corse != null)
                                        {
                                            var count = 1;
                                            foreach (var filename in corse)
                                            {
                                                <div class="pdf-link">
                                                    <span class="pdf-number">@count.</span>
                                                    <a asp-controller="Home" asp-action="WaterMark2" asp-route-id="@filename">@filename</a>
                                                </div>
                                                count++;
                                            }
                                        }
                                        else
                                        {
                                            <div>No recent actions available</div>
                                        }
                                    </td>
                                    <td>
                                        @if (PdfWhiteList != null)
                                        {
                                            var count = 1;
                                            foreach (var filename in PdfWhiteList)
                                            {
                                                <div class="pdf-link">
                                                    <span class="pdf-number">@count.</span>
                                                    <a href="@Url.Action("WaterMark", "Home", new { id = filename })" target="_blank">@filename</a>
                                                </div>
                                                count++;
                                            }
                                        }
                                        else
                                        {
                                            <div>No recent actions available</div>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
               </div>
            </div>
        </div>
    </div>

    <div class="modal fade bd-example-modal-xl" id="ProjectUnderProcess" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Projects Under Process</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <table id="HeldTable11" class="table table-striped table-bordered datatablefordownload">
                        <thead class="paw-sticky-thead">
                            <tr>
                                <th class="text-center f-5 s-no-column paw-w-1">S.No</th>
                                <th class="text-center col-width9 paw-w-9">Name of Sponsor</th>
                                <th class="col-width16">Project Name</th>
                                <th class="text-center col-width9 paw-w-9">From</th>
                                <th class="text-center col-width6">To</th>
                                <th class="text-center">Date</th>
                                <th class="text-center">Stage</th>
                                <th class="text-center">SubStage</th>
                                <th class="text-center col-width6 paw-w-6">Action</th>
                                <th class="paw-w-9">Remark</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Holdproj != null)
                            {
                                int count = 1;
                                foreach (var unitsa in Holdproj)
                                {
                                    <tr>
                                        <td class="s-no-column">@count</td>
                                        <td class="RefLetter-container col-width9">
                                            <div class="noExport">@unitsa.UnitName</div>
                                            <div class="RefLetter">@unitsa.Sponser</div>
                                        </td>

                                        <td>
                                            <div class="RefLetter-container" data-tooltip="@unitsa.ProjName">
                                                <span class="short-text noExport">@truncateText(unitsa.ProjName, 6)</span>
                                                <span class="RefLetter">@unitsa.ProjName</span>
                                            </div>
                                        </td>

                                        <td class="RefLetter-container col-width9">
                                            @unitsa.FromUnitUserDetail
                                            <div class="RefLetter noExport">@unitsa.FromUnitName</div>
                                        </td>

                                        <td class="col-width9">@unitsa.ToUnitName</td>
                                        <td class="col-width10">@unitsa.DateTimeOfUpdate</td>
                                        <td class="col-width10">@unitsa.StageName</td>
                                        <td class="col-width10">@unitsa.StatusName</td>
                                        <td class="col-width6">@unitsa.ActionName</td>

                                        <td class="col-width10">
                                            <div class="RefLetter-container" data-tooltip="@unitsa.Remark">
                                                <span class="short-text noExport">@truncateText(unitsa.Remark, 2)....</span>
                                                <span class="RefLetter">@unitsa.Remark</span>
                                            </div>
                                        </td>
                                    </tr>
                                    count++;
                                }
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>

    <div class="modal fade bd-example-modal-xl" id="WhiteListedProjectDetail" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Whitelisted Projects</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body WhitelistedTablesss">
                    <table id="WhitelistedTable" class="table table-striped table-bordered datatablefordownload paw-table-scroll">
                        <thead class="paw-sticky-thead">
                            @if (Logins?.unitid == 1)
                            {
                                <button class="btn btn-primary" id="AddWhite_proj">Add WhiteList</button>
                            }

                            <tr>
                                <th class="text-center s-no-column paw-w-1">S.No</th>
                                <th class="text-nowrap text-center paw-w-6">Name of Sw Appl</th>
                                <th class="text-nowrap text-center paw-w-12">Hosted On</th>
                                <th class="text-nowrap text-center paw-w-4">Appt</th>
                                <th class="text-nowrap text-center paw-w-4">Sponsor</th>
                                <th class="text-nowrap text-center paw-w-2">Tele No</th>
                                <th class="text-nowrap text-center paw-w-2">Dt of ACG Clearance</th>
                                <th class="text-nowrap text-center paw-w-15">Cert No</th>
                                <th class="text-nowrap text-center paw-w-4">Valid Upto</th>
                                <th class="text-nowrap text-center paw-w-4">Remarks</th>

                                @if (Logins?.unitid == 1)
                                {
                                    <th class="text-nowrap text-center paw-w-4">Action</th>
                                }
                            </tr>
                        </thead>

                        <tbody>
                            @if (WhiteListed != null)
                            {
                                int count = 1;
                                foreach (var unitx in WhiteListed)
                                {
                                    <tr>
                                        <td class="s-no-column">@count</td>

                                        <td class="RefLetter-container paw-w-6">
                                            <span class="noExport">
                                                @(string.IsNullOrEmpty(unitx.ProjName) ? "" : (unitx.ProjName.Length > 10) ? unitx.ProjName.Substring(0, 10) + "...." : unitx.ProjName)
                                            </span>
                                            <div class="RefLetter">@unitx.ProjName</div>
                                        </td>

                                        <td class="col-width9">@unitx.HostedOn</td>
                                        <td>@unitx.Appt</td>
                                        <td>@unitx.Fmn</td>
                                        <td class="col-width6">@unitx.ContactNo</td>
                                        <td class="col-width6">@(unitx.Clearence != null ? unitx.Clearence.ToString("dd-MM-yyyy") : "")</td>

                                        @{
                                            DateTime? clearenceDate = unitx.Clearence;
                                            DateTime? afterThreeYears = null;
                                            if (clearenceDate.HasValue) { afterThreeYears = clearenceDate.Value.AddYears(3); }
                                        }

                                        <td>@unitx.CertNo</td>

                                        <td class="col-width6">
                                            @(afterThreeYears.HasValue ? afterThreeYears.Value.ToString("dd-MM-yyyy") : "")
                                        </td>

                                        <td class="RefLetter-container">
                                            <span class="noExport">
                                                @(string.IsNullOrEmpty(unitx.Remarks) ? "" : (unitx.Remarks.Length > 10) ? unitx.Remarks.Substring(0, 10) + "...." : unitx.Remarks)
                                            </span>

                                            @if (!string.IsNullOrEmpty(unitx.Remarks) && (unitx.Remarks.Length > 10))
                                            {
                                                <div class="RefLetter">@unitx.Remarks</div>
                                            }
                                        </td>

                                        @if (Logins?.unitid == 1)
                                        {
                                            <td>
                                                <center>
                                                    <a class="EditWhiteListedProj" href="#" data-id="@unitx.Id">
                                                        <div>
                                                            <img src="/assets/images/icons/edit.png" alt="Icon" class="paw-edit-icon">
                                                        </div>
                                                    </a>
                                                </center>
                                            </td>
                                        }
                                    </tr>
                                    count++;
                                }
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>

    <div class="modal fade" id="EditWhiteListedProjectModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form id="editWhiteListedForm">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Whitelisted Project</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" id="edit_Id" name="Id" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="edit_ProjName" class="form-label">Name of Sw Appl</label>
                                <input type="text" id="edit_ProjName" name="ProjName" class="form-control" readonly />
                            </div>
                            <div class="col-md-6">
                                <label for="edit_HostedOn" class="form-label">Hosted On</label>
                                <select id="edit_HostedOn" name="mHostTypeId" class="form-select">
                                    <option value="">-- Select Hosted On --</option>
                                    <option value="1">ADN</option>
                                    <option value="2">LAN</option>
                                    <option value="3">Internet</option>
                                    <option value="4">Standalone</option>
                                </select>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="edit_Appt" class="form-label">Appt</label>
                                <input type="text" id="edit_Appt" name="Appt" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="edit_Sponser" class="form-label">Sponsor</label>
                                <select class="form-control" id="edit_Sponser" name="Fmn" data-mdb-select-init>
                                    <option value="">-- Select Sponsor --</option>
                                    @if (ViewBag.Units != null)
                                    {
                                        foreach (var unit in ViewBag.Units)
                                        {
                                            <option value="@unit.UnitName">@unit.UnitName</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="edit_TelNo" class="form-label">Tele No</label>
                                <input type="text" id="edit_TelNo" name="ContactNo" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label for="edit_Clearance" class="form-label">Clearance</label>
                                <input type="date" id="edit_Clearance" name="Clearence" class="form-control" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="edit_Cert" class="form-label">Cert</label>
                                <input type="text" id="edit_Cert" name="CertNo" class="form-control">
                            </div>
                            <div class="col-md-6">
                                <label for="edit_ValidUpto" class="form-label">DDGIT WL DT</label>
                                <input type="date" id="edit_ValidUpto" name="ValidUpto" class="form-control" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="edit_Remarks" class="form-label">Remarks</label>
                                <textarea id="edit_Remarks" name="Remarks" class="form-control" rows="2"></textarea>
                            </div>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Update</button>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <footer class="footers paw-footers">
        <div class="footer-text">
            Copyright &copy; Developed by ASDC, DGIS
        </div>
        <div class="paw-footer-right">
            <span id="dailyCounter"></span>
            <span id="monthlyCounter"></span>
            <span id="totalCounter"></span>
        </div>
    </footer>

    <section class="h-100 gradient-form main-card">
        <div class="container py-5 h-100">
            <div class="row d-flex justify-content-center align-items-center h-100">
                <div class="col-xl-10">
                    <div class="card rounded-3 text-black card-box">
                        <div class="row">
                            <div class="">
                                <div class="">
                                    <div class="text-center">
                                        <img src="~/assets/images/logo1.png" class="paw-logo1" alt="logo" />
                                    </div>

                                    <div class="login paw-login-mt">
                                        <h1 class="login-header">Login</h1>
                                    </div>

                                    <div class="col-12 shadow-lg mb-2 bg-white rounded paw-login-card">
                                        <div id="flush-collapseOne" aria-labelledby="flush-headingOne" data-bs-parent="#accordionFlushExample">
                                            <div class="card-body">
                                                <div class="">
                                                    @Html.AntiForgeryToken()
                                                    <div class="row">
                                                        <div class="col-md-4 col-12">
                                                            <div class="form-group">
                                                                <label for="UserId" class="control-label">Domain ID</label>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-8 col-12">
                                                            <div class="form-group">
                                                                <input type="text" id="UserId" name="UserId" class="form-control readonly" value="@username" readonly required />
                                                                @Html.ValidationMessageFor(model => model.UserId, "", new { @class = "text-danger" })
                                                            </div>
                                                        </div>

                                                        <div class="col-md-4 col-12">
                                                            <div class="form-group">
                                                                <label for="RoleId" class="control-label">Role</label>
                                                            </div>
                                                         </div>
                                                        <div class="col-md-8 col-12">
                                                            <div class="form-group">
                                                                <input type="text" id="RoleId" name="RoleId" class="form-control alphanumeric-only readonly" value="@role" readonly required />
                                                            </div>
                                                        </div>

                                                        <div class="col-md-12 col-12 text-center">
                                                            <div class="form-group">
                                                                <button type="button"
                                                                        class="btn btn-primary btn-block @processBtnClass"
                                                                        id="ProcessId"
                                                                        data-button-text="@ButtonText">
                                                                    @ButtonText
                                                                </button>
                                                            </div>
                                                        </div>


                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gradient-custom-2">
                            <div class="text-white px-3 py-4 mx-md-4">
                                <div class="cards-list">
                                    <div class="row box card-r">
                                        <div class="col-md-4" id="PolicyWhiteList">
                                            <div class="card1 hover-point">
                                                <div class="card_title title-white paw-card-title">
                                                    <p class="font-d">Policies on WhiteListing</p>
                                                </div>
                                                <div class="card_image"><img src="~/assets/images/Policy1.png" class="images" /></div>
                                            </div>
                                        </div>

                                        <div class="col-md-4" id="whitelistCard">
                                            <div class="card1 hover-point">
                                                <div class="card_title title-white paw-card-title">
                                                    <p class="font-d">Real Time Proj <br />Status</p>
                                                </div>
                                                <div class="card_image"><img src="~/assets/images/projectunder.png" class="images" /></div>
                                            </div>
                                        </div>

                                        <div class="col-md-4" id="WhiteListedProject">
                                            <div class="card1 hover-point">
                                                <div class="card_title title-white paw-card-title">
                                                    <p class="font-d">View WhiteListed Projs</p>
                                                </div>
                                                <div class="card_image"><img src="~/assets/images/Completed1.png" class="images" /></div>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>

                    </div> <!-- card -->
                </div>
            </div>
        </div>
    </section>

    <div class="modal fade bd-example-modal-xl" id="WhiteListModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add to WhiteList</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" data-cancel="true"></button>
                </div>

                <div class="modal-body">
                    <form id="WhiteListForm">
                        <div class="row">
                            <div class="col-md-4 mb-2">
                                <label for="swName" class="form-label">
                                    Name of SW Appl<span class="required-star">*</span>
                                </label>
                                <input type="text" class="form-control" id="swName" name="swName" required placeholder="Enter Software/Application Name" />
                                <div class="invalid-feedback paw-invalid-red">This field is required.</div>
                            </div>

                            <div class="col-md-4 mb-2">
                                <label for="hostedOn" class="form-label">Hosted On<span class="required-star">*</span></label>
                                <select class="form-control" id="hostedOn" name="hostedOn" required>
                                    <option value="">-- Select Hosted On --</option>
                                    @if (ViewBag.hosttype != null)
                                    {
                                        foreach (var unit in (IEnumerable<dynamic>)ViewBag.hosttype)
                                        {
                                            <option value="@unit.HostTypeID">@unit.HostingDesc</option>
                                        }
                                    }
                                </select>
                                <div class="invalid-feedback paw-invalid-red">This field is required.</div>
                            </div>

                            <div class="col-md-4 mb-2">
                                <label for="appt" class="form-label">Appt<span class="required-star">*</span></label>
                                <input type="text" class="form-control" id="appt" name="appt" required placeholder="Enter Appointment" />
                                <div class="invalid-feedback paw-invalid-red">This field is required.</div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-2">
                                <label for="sponsor" class="form-label">Sponsor (Unit)<span class="required-star">*</span></label>
                                <select class="form-control" id="sponsor" name="sponsor" required>
                                    <option value="">-- Select Sponsor --</option>
                                    @if (ViewBag.Units != null)
                                    {
                                        foreach (var unit in ViewBag.Units)
                                        {
                                            <option value="@unit.UnitName">@unit.UnitName</option>
                                        }
                                    }
                                </select>
                                <div class="invalid-feedback paw-invalid-red">This field is required.</div>
                            </div>

                            <div class="col-md-4 mb-2">
                                <label for="telNo" class="form-label">Tele No<span class="required-star">*</span></label>
                                <input type="text" class="form-control" id="telNo" name="telNo" required placeholder="Enter Telephone Number" />
