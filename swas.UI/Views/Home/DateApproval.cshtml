	Login Logins = SessionHelper.GetObjectFromJson<Login>(HttpContextAccessor.HttpContext.Session, "User");
}
<link href="~/css/timeline.css" rel="stylesheet" />
<style>
	.bold-text {
		font-weight: bold;
	}

	.tabs__head li {
		margin-right: 10px;
	}

	.tabs__head a {
		text-decoration: none;
		padding: 10px 15px;
		border: 1px solid #ccc;
		background-color: #fff; /* Set the default background color */
	}

		.tabs__head a.active-link {
			background-color: white; /* Set the active background color to white */
			border-bottom: 20px solid #dee2e6; /* Adjust this as needed */
		}

	.active-link {
		background-color: #004a99;
		color: white !important;
		border-radius: 4px;
		padding: 6px 12px;
	}

	#projectNameDropdown {
		position: absolute;
		max-height: 200px;
		overflow-y: auto;
		border: 1px solid #ccc;
		background-color: #fff;
		width: 250px;
		z-index: 1000;
		list-style: none;
		/*  margin-left: 766px;
				margin-top: 45px; */
		padding: 0;
	}

		#projectNameDropdown li {
			padding: 8px;
			cursor: pointer;
		}

			#projectNameDropdown li:hover {
				background-color: #f1f1f1;
			}

	.tabs__head a.active-link {
		background-color: white; /* Set the active background color to white */
		border-bottom: 20px solid #dee2e6; /* Adjust this as needed */
	}
</style>

<body>


	<div id="tabledateContainer">
		<div class="text-center mb-4">
			<h3 class="fw-bold text-warning" style="text-transform: uppercase; letter-spacing: 1px;">
				APPROVAL FOR LEGACY PROJECTS
			</h3>
			<small class="text-muted fst-italic">Backdated calendar projects or ongoing legacy project intake</small>




			<ul class="tabs__head">
				<li>
					<a class="active-link mr-2" href="#" data-tab="Ingest_Request" id="tabinbox">
						<span class="fa fa-download"></span>&nbsp;Ingest Request
						<span id="IngestionReq" class="badge3 d-none IngestionReq" style="font-size:0.7rem;">0</span>
					</a>
				</li>
				<li>
					<a href="#" data-tab="Find_approval" id="tabsent" style="width:220px">
						<span class="fa fa-edit"></span>&nbsp;Approval for other
						<span id="IngestionReqforother" class="badge3 d-none IngestionReqforother" style="font-size:0.7rem;">0</span>
					</a>
				</li>
			</ul>
		</div>
		<div class="tab-content" id="Ingest_Request">
			<div class="card radius-10 w-100">
				<div class="card-body" style="overflow-y:auto; height:700px">
					<span id="IpAddress" style="display:none;"> @TempData["ipadd"]</span>
					<table id="TableType1" class="table table-striped table-bordered">
						<thead>
							<tr>
								<th>S/No</th>
								<th>Project Name</th>
								<th>User</th>
								<th>From Unit</th>
								<th>Request Date</th>
								<th>Admin Approval Date</th>
								<th>Requested Remarks</th>
								<th>Action</th>
							</tr>
						</thead>
						<tbody id="DateApproval"></tbody>
					</table>
				</div>
			</div>
		</div>
		<div class="modal fade" id="ProjFwdHistory" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
			<div class="modal-dialog modal-xl" role="document">
				<div class="modal-content">
					<div class="modal-header">

						<h4 class="modal-title" id="lblHistory"></h4>
						<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>

					<div class="modal-body ml-lg-5">

						<div class="timeline" id="projectLegacyhistory">
						</div>
					</div>

				</div><!-- modal-content -->
			</div><!-- modal-dialog -->
		</div>
	</div>



	<div class="tab-content" id="Find_approval" style="display: none;">
		<!-- Approval for Other Content -->



		<div class="card radius-10 w-100" style="height:675px">

			<div class="mb-3 position-relative">
				<label for="Find_forApproval" class="form-label fw-bold">Search for Legacy Approval:</label>

				<input type="text" id="Find_forApproval" class="form-control d-inline-block ms-2 mt-2" style="width:300px;" autocomplete="off" placeholder="Search Project By Name">

				<ul id="projectNameDropdown" class="dropdown-menu show mt-1" style=" display: none; width:650px; margin-left:210px"></ul>

				<input type="hidden" id="ProjId" />
				<input type="hidden" id="ProjName" />
			</div>

			<div class="card-body" style="overflow-y:auto; height:700px">
				<span id="IpAddress1" style="display:none;"> @TempData["ipadd"]</span>
				<table id="TableType2" class="table table-striped table-bordered">
					<thead>
						<tr>
							<th>S/No</th>
							<th style="width:200px">Project Name</th>
							<th style="width:150px">User</th>
							<th style="width:100px">From Unit</th>
							<th style="width:100px">Request Date</th>
							<th style="width:120px">Admin Approval Date</th>
							<th style="width:120px">Requested Remarks</th>
							<th>Action</th>
						</tr>
					</thead>
					<tbody id="DateApproval1"></tbody>
				</table>
			</div>
		</div>
	</div>
	

</body>

