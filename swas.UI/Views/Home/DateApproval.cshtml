@section Scripts {

	<script>
				function formatRemarks(remarks) {
			if (!remarks) return "<span class='text-muted'>-</span>";

			let words = remarks.split(" ");
			let formatted = "";
			for (let i = 0; i < words.length; i++) {
				formatted += words[i] + " ";
				if ((i + 1) % 5 === 0) {
					formatted += "<br>";
				}
			}
			return formatted.trim();
		}
