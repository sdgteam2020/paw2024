}

@* <link href="~/css/ProjComments.css" rel="stylesheet" /> *@
<link href="~/css/chatbox.css" rel="stylesheet" />
<div id="MyDatacontainer" class="col-lg-12 col-md-12 col-sm-12"></div>

<div class="row">
    <div id="AddStatusDetails" class="col-lg-12 col-md-12 col-sm-12">
        <h5 class="text-center mb-4 underline-h5 pc-heading-h5">
            <span>
