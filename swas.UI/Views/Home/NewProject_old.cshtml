<script>
    var flag = "@flag";
    var ButtonText = "@ButtonText";
    var username = "@username";
    var ip = '@ip';
</script>
<script src="~/developerjs/newproject.js"></script>
<script src="~/developerjs/commanfordatatable.js"></script>
