@using swas.DAL.Models
@{
    ViewData["Title"] = "Documents Details";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int sno = 0;
}
<link href="~/css/documentHistory.css" rel="stylesheet"/>
<div>
    <h5 class="text-center mb-4 underline-h5 custom-h5">
        <span>
            Project Name: @ViewBag.ProjName
        </span>
    </h5>
</div>

<div class="row">
    <div id="DocumentsMerge" class="col-6 custom-scroll">
        <div class="card radius-12">
            <div class="vertical-table">
                <table id="Documents" class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>S/No</th>
                            <th>Document Desc</th>
                            <th>File Name</th>
                            <th>Checklist</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tst in ViewBag.result)
                        {
                            <tr>
                                <td>
                                    @{
                                        sno++;
                                    }
                                    @sno
                                </td>
                                <td>@tst.ActFileName</td>
                                <td>@tst.Reamarks</td>
                                <td>
                                    <input type="checkbox" class="checklist-item" data-att-path="@tst.AttPath" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <button type="button" id="downloadButton" class="btn-preview">PDF PREVIEW</button>
            </div>
        </div>
    </div>

    <div id="mergedpdf" class="col-6">
        <div class="card radius-12">
            <div class="container">
                <h5 class="text-center mb-4 underline-h5 custom-h5">
                    <span>PDF PREVIEW</span>
                </h5>
                <div id="pdf-container"></div>
            </div>
        </div>
    </div>
</div>


<script src="~/DeveloperJs/Documents.js"></script>