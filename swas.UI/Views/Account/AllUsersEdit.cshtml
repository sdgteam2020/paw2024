@model InputModel
@using Microsoft.AspNetCore.Identity;
@using Newtonsoft.Json;
@using swas.BAL.Helpers
@using swas.BAL.Repository
@using swas.DAL
@using swas.DAL.Models
@using swas.BAL.Interfaces
@using swas.BAL.DTO
@inject IHttpContextAccessor HttpContextAccessor



@{

    Layout = "~/Views/Shared/_Layout.cshtml";

    var roles = (List<Types>)ViewData["roles"];
    var iamuser = (List<AddlTask>)ViewData["IAMUser"];
    var units = (List<UnitDtl>)ViewData["Unit"];
    var typesList = ViewBag.Type;
    var Rank = (List<mRank>)ViewData["rank"];
    Login Logins = SessionHelper.GetObjectFromJson<Login>(HttpContextAccessor.HttpContext.Session, "User");
    bool isRestricted = Logins.unitid != 1;
}

<link href="~/css/AllUsersEdit.css" rel="stylesheet"/>


<div>
    <div class="card radius-10 up-card-wrap">
        <div class="card-body up-card-inner">
            <div class="card-d btn-primary card-header up-header">
                <h3 class="text-center card-show font-weight-light my-4"><u>Update Profile</u></h3>
            </div>

            <form method="post" action="@Url.Action("UpdateUserEdit", "Account")">
                <div class="row">
                    <div class="col-md-12">

                        <table class="table table-striped table-bordered">
                            <tr>
                                <td>
                                    <label asp-for="UserName" class="label control-label up-label-m5">Regn Id (UserName)</label>
                                </td>
                                <td class="up-td-w65">
                                    <input asp-for="UserName" class="form-control alphanumeric-only" maxlength="20"
                                           aria-required="true" placeholder="Regn Id Reqd for Login & More Users Regn for this unit" />
                                    <input hidden asp-for="Id" />
                                    <span asp-validation-for="UserName" class="text-danger"></span>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <label asp-for="RankId" class="label control-label up-label-m5">Select Rank</label>
                                </td>
                                <td>
                                    <select asp-for="RankId" class="form-control dropdownsearch" aria-required="true">
                                        @foreach (var rank in Rank)
                                        {
                                            <option value="@rank.Id">@rank.RankName</option>
                                        }
                                    </select>
                                    <span asp-validation-for="RankId" class="text-danger"></span>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <input hidden asp-for="RankName" class="form-control" maxlength="100" aria-required="true" placeholder="Offrs Name" />
                                    <label asp-for="OfficerName" class="label control-label up-label-m5"> Name</label>
                                </td>
                                <td>
                                    <input asp-for="OfficerName" class="form-control" maxlength="100" aria-required="true" placeholder="Offrs Name" />
                                    <span asp-validation-for="OfficerName" class="text-danger"></span>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <label asp-for="appointment" class="label control-label up-label-m5">Appointment</label>
                                </td>
                                <td>
                                    <input asp-for="appointment" class="form-control alphanumeric-only" maxlength="35"
                                           aria-required="true" placeholder="Appointment" />
                                    <span asp-validation-for="appointment" class="text-danger"></span>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <label asp-for="Tele_Army" class="label control-label up-label-m5">Tele No (Army)</label>
                                </td>
                                <td>
                                    <input asp-for="Tele_Army" class="form-control" maxlength="35" aria-required="true" placeholder="Tele No (Army)" />
                                    <span asp-validation-for="Tele_Army" class="text-danger"></span>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <label asp-for="unitId" class="label control-label">Select Unit</label>
                                </td>
                                <td>
                                    <select asp-for="unitId" class="form-control dropdownsearch">
                                        @foreach (var unit in units)
                                        {
                                            <option value="@unit.unitid">@unit.UnitName</option>
                                        }
                                    </select>
                                    <span asp-validation-for="unitId" class="text-danger"></span>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <label asp-for="RoleName" class="label control-label">Select Role</label>
                                </td>
                                <td>
                                    <select asp-for="RoleName" class="ms form-control inputs dropdownsearch">
                                        @foreach (var Role in typesList)
                                        {
                                            if (ViewData["ty"].ToString() == Role.Name)
                                            {
                                                <option selected value="@Role.Id">@Role.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@Role.Id">@Role.Name</option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="RoleName" class="text-danger"></span>
                                </td>
                            </tr>

                            <tr>
                                <td></td>
                                <td>
                                    <div class="input-group" id="show_hide_password">
                                        <input asp-for="Password" hidden="hidden" maxlength="15" class="ms form-control inputs" readonly="readonly"
                                               autocomplete="new-password" aria-required="true" id="myInput" placeholder="Password" />
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                </td>
                            </tr>

                            <tr>
                                <td></td>
                                <td>
                                    <div class="input-group" id="show_hide_password">
                                        <input asp-for="ConfirmPassword" hidden="hidden" maxlength="15" class="ms form-control inputs" readonly="readonly"
                                               autocomplete="new-password" aria-required="true" id="myCnfInput" placeholder="Confirm Password" />
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>
                                </td>
                            </tr>

                            <tr class="up-row-center">
                                <td colspan="2">
                                    <div class="col-12 up-msg-red">@TempData["msg"]</div>
                                </td>
                            </tr>
                        </table>

                    </div>

                    <div>
                        <div class="col-md-12">
                            <div class="col-md-12">
                                <center>
                                    <button type="submit" class="btn btn-save up-btn-blue" id="AddlDetails">
                                        Update
                                    </button>

                                    <span class="up-ml-20">
                                        <button type="button" class="btn btn-save up-btn-blue">
                                            <a href="/Account/GetsAllUsers" class="up-btn-link-white">
                                                Back
                                            </a>
                                        </button>
                                    </span>
                                </center>
                            </div>
                            <br>  <br> <br> <br> <br> <br> <br>
                        </div>
                    </div>

                </div>
            </form>

        </div>
    </div>
</div>
<script src="~/DeveloperJs/AllUsersEdit.js"></script>






