@using swas.DAL.Models
@{

    ViewData["Title"] = "Proj Comments";
    int sno = 0;
}
<link href="~/assets/css/tooltip.css" rel="stylesheet" />
<link href="~/jquery/autocomplete.css" rel="stylesheet" />
<link href="~/css/projcomments.css" rel="stylesheet" />
<link href="~/css/_projectpendingstatus.css" rel="stylesheet" />

<!----Table for Stakeholder Status Change----->
<div class="card-body mt-5">
    <div class="card radius-10 w-100">
        <div class="card-body">
            <div class="mb-3">
                <!-- Button group -->
                <div class="col-md-24 d-flex align-items-center" role="group">
                    <button type="button" class="btn btn-danger btn-sm mr-2 cmtbtn btn-3d" id="btnPending">Pending</button>
                    <button type="button" class="btn btn-success btn-sm mr-2 cmtbtn btn-3d" id="btnAccepted">Accepted</button>
                    <button type="button" class="btn btn-warning btn-sm mr-2 cmtbtn btn-3d text-white" id="btnObsn">Obsn</button>
                    <button type="button" class="btn btn-danger btn-sm mr-2 cmtbtn btn-3d" id="btnRejected">Rejected</button>
                    <button type="button" class="btn btn-info btn-sm mr-2 text-white cmtbtn btn-3d" id="btnInfo">Info</button>
                    <div class="ml-auto">
                        <div class="input-group col-md-6 ml-2">
                            <div class="input-group-prepend">
                                <span class="input-group-text bold-text">
                                    <svg xmlns="" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                                    </svg>Search Project
                                </span>
                            <input type="text" id="CommentProject" class="form-control" placeholder="Search project for Comment" />
                            </div>
                        </div>
                    </div>
                    
                </div>
                <div class="mt-2">
                  

                </div>
                <!-- Section heading -->
                <div class="header-container text-center">
                    <h4 class="text-light ">
                        StakeHolder Comments
                    </h4>
                </div>
                
            </div>

            <table id="Comment" class="table table-striped table-bordered">
                <!-- Table header -->
                <thead>
                    <tr>

                        <th class="noExport d-none"></th>
                        <th class="s-no-column ">Ser No</th>
                        <th>Project Name</th>
                        <th>Stakeholder</th>
                        <th>Recd on</th>
                        <th>Status</th>
                        <th class="noExport">Action</th>

                    </tr>
                </thead>

                <tbody id="DetailBody">
                </tbody>

            </table>


        </div>
    </div>
</div>



<script src="~/developerjs/mtable.js"></script>
<script src="~/developerjs/projectstkholdercomments.js"></script>
<script src="~/developerjs/NewProject.js"></script>
<script src="~/developerjs/CommanDatatable.js"></script>
<script src="~/developerjs/Tooltip.js"></script>
 
<script src="~/jquery/autocomplete.js"></script>
