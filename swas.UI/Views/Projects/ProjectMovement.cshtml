@using swas.BAL.DTO
@model List<DTOProjectMovHistorypsm>
@{
    ViewData["Title"] = "Project Movement  Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int sno = 1;
}

<head>
    <script src="~/js/jquery-ui.min.js"></script>
    <link href="~/css/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/css/ProjectMovement.css" rel="stylesheet" />
</head>

<div id="searchContainer" class="search-container mt-5">
    <form class="form-group" asp-action="GetProjLogview" method="post" id="searchFormProjName">
        <div class="row justify-content-center">
            <label class="col-sm-4 col-form-label fw-bold text-end">Search Project Name : </label>
            <div class="col-md-3">
                <div class="form-group row mb-2 align-items-center" id="suggesstion-box">
                    <span class="d-none" id="ProjectId">0</span>
                    <span class="d-none" id="PslmId">0</span>

                    <input class="form-control" placeholder="Type Project Name" id="txtProjectName" name="txtProjectName" data-val="true" />
                    <span class="text-danger field-validation-valid" data-valmsg-for="txtProjectName" data-valmsg-replace="true"></span>
                </div>
            </div>
        </div>
    </form>
</div>

<div id="tableProjContainer">
    <div class="card radius-10 w-100">
        <div class="card-body pm-overflow-scroll">
            <table id="moventdata" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th class="d-none pm-th-w23">Ser No</th>
                        <th class="pm-th-center pm-th-w23">Ser No</th>
                        <th class="pm-th-center">Date</th>
                        <th class="pm-th-center">From (User Name/Domain ID)</th>
                        <th class="pm-th-center">To StakeHolder</th>
                        <th class="pm-th-center">Stage</th>
                        <th class="pm-th-center">SubStage</th>
                        <th class="pm-th-center">Action</th>
                        <th class="pm-th-center">Remarks</th>
                        <th class="pm-th-center">#Att</th>
                        <th class="pm-th-center">Edit</th>
                    </tr>
                </thead>

                <tbody id="ProjectMovement"></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="ProjFwdEdit" tabindex="-1" role="dialog" data-bs-backdrop="static" data-bs-keyboard="false" aria-labelledby="staticBackdropLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl custom-modal-size">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="fwdModal">Mov History</h5>
                <span class="d-none" id="spanProjectId">0</span>
                <span class="d-none" id="spanEditPslmId">0</span>
                <span class="d-none" id="SpnFwdStakeHolderId">0</span>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="row">
                    <div class="col-md-12">

                        <div class="card">
                            <div class="modal-header">
                                <h6 class="card-title">Pl select appropriate details Before Dispatch of Project to Next Stakeholder </h6>
                            </div>

                            <div class="card-body">
                                <div class="form-row">

                                    <div class="form-group col-md-6 ProjectsFwd">
                                        <label for="inputEmail4">Stage</label>
                                        <select class="form-control requiredField pm-w-100" tabindex="-1" name="fwdoffrs" required id="ddlfwdStage">
                                            <option value="0">Select Stage</option>
                                        </select>
                                    </div>

                                    <div class="form-group col-md-6 ProjectsFwd">
                                        <label for="SubStage">Sub Stage</label>
                                        <select class="form-control requiredField pm-w-100" tabindex="-1" name="fwdoffrs" required id="ddlfwdSubStage">
                                            <option value="0">Select Sub Stage</option>
                                        </select>
                                    </div>

                                    <div class="form-group col-md-6 ProjectsFwd">
                                        <label for="SubStage">Action</label>
                                        <select class="form-control requiredField pm-w-100" tabindex="-1" name="fwdoffrs" required id="ddlfwdAction">
                                            <option value="0">Select Action</option>
                                        </select>
                                    </div>

                                    <div class="form-group col-md-6 ProjectsFwd">
                                        <label for="SubStage">Fwd To</label>
                                        <select class="form-control requiredField pm-w-100" tabindex="-1" name="fwdoffrs" required id="ddlfwdFwdTo">
                                            <option value="0">Select Fwd To</option>
                                        </select>
                                    </div>

                                    <div class="form-group col-md-6 ProjectsFwd">
                                        <label for="SubStage">Remarks</label>
                                        <textarea class="form-control requiredField pm-w-100" id="txtRemarksfwd"></textarea>
                                    </div>

                                    <div class="form-group col-md-6 ProjectsFwd">
                                        <label>Date of Fwd:</label>
                                        <input id="TimeStampToProjfwd" type="datetime-local" class="datePicker form-control requiredField" />
                                    </div>

                                    <div class="form-group col-md-6 Attmenthistory d-none">
                                        <label for="SubStage">Attach Document Description</label>
                                        <textarea class="form-control requiredFieldAttch" id="Reamarks"></textarea>
                                    </div>

                                    <div class="form-group col-md-6 Attmenthistory d-none">
                                        <label for="SubStage">Upload Pdf File</label>
                                        <input class="form-control requiredFieldAttch" type="file" id="pdfFileInput">
                                    </div>

                                    <div class="form-group col-md-12 Attmenthistory d-none text-center">
                                        <button class="btn btn-warning" type="button" id="btnAttchMultiforpsmid">Upload File</button>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="col-md-12 Attmenthistory d-none">
                    <div class="card">
                        <div class="modal-header"><h5 class="card-title">Projects Move Att Details</h5></div>
                        <div class="card-body pm-overflow-auto">
                            <table class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>Delete</th>
                                        <th>Docu Desc</th>
                                        <th>File Name</th>
                                        <th>Timestamp</th>
                                    </tr>
                                </thead>
                                <tbody id="DetailBody3"></tbody>
                            </table>
                        </div>
                    </div>

                    <div id="uploadLoader" class="pm-upload-overlay">
                        <div class="d-flex justify-content-center align-items-center h-100">
                            <div class="text-center">
                                <div class="spinner-border text-success pm-spinner-lg" role="status">
                                    <span class="visually-hidden">Uploading...</span>
                                </div>
                                <div class="mt-3 text-white">Uploading, please wait...</div>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="form-group col-md-12 mt-4 text-center">
                    <input type="button" id="btnFwdNext" value="Update and Upload Docu's" class="btn btn-primary btn-lg ProjectsFwd" />
                    <input type="button" id="btnFwdConfirm" value="Confirm" class="btn btn-primary btn-lg Attmenthistory d-none" />
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="myModalPagehistoryAttechment" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg custom-modal-size">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">ATTACHMENTS</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="myModalContenthistoryAttechment"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="EditComments" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl custom-modal-size">
        <div class="modal-content pm-modal-ml0">
            <div class="modal-header">
                <h5 class="modal-title btn-add-comment" id="Projname">Project Name:</h5>
                <span class="d-none" id="StkcommentId"></span>
                <span class="d-none" id="StkPsmid"></span>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="card radius-12">
                            <div class="text-with-icon underline-h7">
                                <span class="pm-emoji">&#128172;</span>
                                <h7 class="text-center mb-4 underline-h7 pm-h7-title">
                                    Add Comments for Project
                                </h7>
                            </div>

                            <div class="container mt-1">
                                <div class="row justify-content-center">
                                    <div class="col-md-10 form-container">
                                        <div id="projectcommentforstackholder">
                                            <div class="row">
                                                <div class="mb-3">
                                                    <div>
                                                        <label id="Comm"><b>Comment</b> <span class="required-indicator">*</span></label>
                                                        <textarea id="edtCmts" class="form-control requiredField pm-textarea-240" rows="4"></textarea>
                                                        <div class="invalid-feedback">Please provide the Comments</div>
                                                    </div>

                                                    <div class="mb-2">
                                                        <label class="control-label">
                                                            <b>Status</b>
                                                            <span class="text-danger"><font class="pm-required-star"><b>*</b></font></span>
                                                        </label>

                                                        <select class="form-control requiredField" id="ddlStatus">
                                                            <option value="">Select a Status</option>
                                                        </select>

                                                        <div class="invalid-feedback">Select Status Required</div>
                                                        <div class="invalid-feedback">Please select a Status.</div>
                                                    </div>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="control-label"><b>Date of Post:</b></label>
                                                    <input id="CommentDateFwd" type="datetime-local" class="datePicker form-control requiredField" />
                                                </div>

                                                <div class="form-group text-left">
                                                    <button type="button" class="btn btn-primary" id="btnCommentUpdate">Update Comments</button>
                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="col-md-6">
                        @Html.Partial("_ProjectComments");
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="uploadLoader" class="pm-upload-overlay">
        <div class="d-flex justify-content-center align-items-center h-100">
            <div class="text-center">
                <div class="spinner-border text-success pm-spinner-lg" role="status">
                    <span class="visually-hidden">Uploading...</span>
                </div>
                <div class="mt-3 text-white">Uploading, please wait...</div>
            </div>
        </div>
    </div>
</div>

 
<script src="~/DeveloperJs/ProjectMovement.js"></script>
<script src="~/developerjs/mtable.js"></script>
