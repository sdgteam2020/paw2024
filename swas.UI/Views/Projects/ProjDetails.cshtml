			<img src="~/assets/images/inbox.png" width="20" height="20" class="me-1" /> Inbox
		</a>
	</li>

	<li class="me-2 mb-1">
		<a href="#" class="d-flex align-items-center" data-tab="sent" id="tabsent">
			<img src="~/assets/images/sentmail.png" width="20" height="20" class="me-1" /> Sent
		</a>
	</li>

	<li class="me-2 mb-1">
		<a href="#" data-tab="completed" id="tabcompleted" class="d-flex align-items-center" style="min-width:180px;">
			<img src="~/assets/images/completed.png" width="20" height="20" class="me-1" /> Completed (Hosted On ADN)
		</a>
	</li>

	<li class="me-2 mb-1">
		<a href="#" data-tab="Remainder" id="tabRemainder" class="d-flex align-items-center">
			<img src="~/assets/images/bell.png" width="25" height="25" class="me-1" /> Reminder
		</a>
	</li>

	<li class="me-2 mb-1">
		<a href="#" data-tab="ToCc" id="tabCC" class="d-flex align-items-center">
			<img src="~/assets/images/draft.png" width="20" height="20" class="me-1" /> Cc Projects
		</a>
	</li>
			<li class="red-text" id="blinking-li">
				&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
				Inbox -->> click on project name for Add Comments, Attach file and Fwd to Stakeholders/Units
			</li>

		</ul>

		@{
			snoinbox = 0;
		}


		<div class="tabs__content">
			<div class="tabs__content__item active-tab" id="inbox" style="height:100%; ">
				<div class="content" style="height:100%;">
					<div class="card radius-10 w-100" style="height:100%;">
						<div class="card-body" style="height:100%; overflow-y: scroll;">

							<table id="Inbox" class="table table-striped table-bordered">
								<thead>
									<tr>
										<th class="s-no-column">Ser No</th>
										<th style="width:20%">Proj Name</th>
										<th>Sponsor</th>
										<th style="width:9%;">From</th>
										@* <th class="to-unit-name">To Unit Name</th> *@
										<th>Received On</th>
										<th>Stage</th>
										<th>SubStage</th>
										<th>Action</th>
										<th class="projaction">Project Action</th>
										<th>Ingest Legacy Project</th>
									</tr>
								</thead>

								<tbody>

									@foreach (var project in Model.InBox)
									{
										string @classname = "";
										if (project.IsRead == false)
										{
											classname = "bold-text";
										}
										else
										{
											classname = "";
										}



										<tr class="@classname">

											<td data-order="@snoinbox">
												@{
													snoinbox++;
												}
												<span>@snoinbox</span>
												@* Visible content *@

												@if (@project.HasRemainder1 == true&& project.IsCc ==false)
												{
													<div class="hover-container" style="position: relative; display:inline" id="notificationContainer @project.ProjId">
														<div style="position: relative; display: inline-block; margin-left: 5px;" id="ReadRemainderNoti" data-projid="@project.ProjId">
															<img src="/assets/images/icons/notification-unscreen.gif" alt="Notification" style="width:30px; height:30px;" />

															@if (project.RemainderCount > 0)
															{
																<span class="badge3" id="Remainderbedge" style="position: absolute; top: -5px; right: -5px; background-color: red; color: white; border-radius: 50%; padding: 2px 6px; font-size: 12px;">
																	@project.RemainderCount
																</span>
															}
														</div>
														@if (!string.IsNullOrWhiteSpace(project.LatestRemarks))
														{
															<div class="hover-popup custom-popup-glass">
																<h6 class="popup-title"> Remarks</h6>
																<ul class="popup-list">
																	@if (!string.IsNullOrWhiteSpace(project.LatestRemarks))
																	{
																		var remarks = System.Text.RegularExpressions.Regex
																		.Split(project.LatestRemarks ?? "", @"(?=\([^)]+\):)")
																		.Where(r => !string.IsNullOrWhiteSpace(r));
																		foreach (var remark in remarks)
																		{
																			<li style="margin-bottom: 5px;">
																				<i class="fas fa-comment-dots text-primary"></i>
																				@remark
																			</li>
																		}
																	}
																	else
																	{
																		<li><i class="fas fa-info-circle"></i> No remarks available</li>
																	}
																</ul>
															</div>
														}



													</div>
												}






											</td>


											<td class="f-12">

												<span class="d-none" id="SpnCurrentProjId">@project.ProjId</span>
												<span class="d-none" id="SpnCurrentpsmId">@project.PsmIds</span>
												<span class="d-none" id="SpnStakeHolderId">@project.StakeHolderId</span>
												<span class="d-none" id="LatestActionType">@project.LatestActionType</span>
												@* <span class="d-none" id="SpnTimeStampId">@project.TimeStamp.ToString().Substring(0, 10)</span> *@
												<span class="d-none" id="SpnTimeStampId">@project.TimeStamp</span>
												<span class="d-none" id="SpnStageId">@project.StageId</span>
												<span class="d-none" id="SpnTimeStatusId">@project.StatusId</span>

												<span class="d-none" id="SpnprojectIsProcess">@project.IsProcess</span>
												<span class="d-none" id="SpnTimeActionId">@project.ActionId</span>
												<span class="d-none" id="SpnTimeToUnitId">@project.ToUnitId</span>
												<span class="d-none" id="SpnDate_type">@project.Date_type</span>
												<span class="d-none" id="SpnApprove">@project.AdminApprovalStatus</span>
												<a data-proj-name="@project.ProjName" id="ProjectName" class="ProjName" data-proj-id="@project.ProjId" href="/Projects/ProjHistory?EncyID=@project.EncyID&Type=XRDC&psmid=@project.PsmIds">
													<div class="tooltip-container" data-tooltip="@project.ProjName">
														<span class="short-text">@truncateText(project.ProjName, 6)</span>
														<span class="tooltip tooltip-text">@project.ProjName</span>
													</div>
												</a>
											</td>



											<td class="RefLetter-container">
												@project.UnitName
												<div class="RefLetter">
													@project.Sponsor
												</div>
											</td>
											<td>
												<div class="d-flex">
													<div class="col-md-8">
														<div class="RefLetter-container ">
															@project.FromUnitUserDetail
															<div class="RefLetter">
																@project.FromUnitName
															</div>
														</div>
													</div>

													@if (project.IsCc == true || project.IssentCC == true)
													{
														<div class="col-md-2">
															<div class="RefLetter-container btn btn-warning p-2" style="padding: 1px !important;font-size: 13px !important;margin-top: 1px;">
																<div class="tooltip-container" data-tooltip="@project.CCUnitName">
																	@if (project.IsCc == true)
																	{
																		<span class="short-text" id="IsccForRemoveRow">Cc</span>
																	}
																	else
																	{

																		<span class="short-text">Cc</span>

																	}
																	<span class="tooltip tooltip-text">@project.CCUnitName</span>
																</div>

															</div>
														</div>
													}
												</div>
											</td>

											@* <td>@project.ToUnitName</td> *@
											@* <td>@project.TimeStamp.ToString().Substring(0,10)</td> *@
											<td class="TimeStampForcheckdate">@project.TimeStamp</td>
											<td>@project.Stage</td>
											<td>@project.Status</td>
											<td>@project.Action</td>




											<td>
												<div class="row ">
													<div class="col-md-12 d-flex">
														@* <div class="mr-2">
                                                        @if (project.StageId == 1 && project.IsProcess == false && Convert.ToInt32(ViewBag.unitid) == 1)
                                                        {
                                                            <a href="javascript:void(0);" class="processDetail mr-2" data-id="@project.EncyPsmID">
                                                                <img src="/assets/images/icons/process1.png" alt="Icon" style="height: 22px;">
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <button type="button" class="btn btn-success btn-Fwd" data-proj-name="@project.ProjName" style="padding: 1px !important;font-size: 13px !important;margin-top: 1px;">Fwd</button>
                                                        }
                                                    </div> *@

														<div class="mr-2">
															@if (project.StageId == 1 && project.IsProcess == false && Convert.ToInt32(ViewBag.unitid) == 1)
															{
																<a href="javascript:void(0);" class="processDetail mr-2" data-id="@project.EncyPsmID">
																	<img src="/assets/images/icons/process1.png" alt="Icon" style="height: 22px;">
																</a>
															}
															else if (project.IsCc == false)
															{
																<button type="button" class="btn btn-success btn-Fwd" data-Date_type="@project.AdminApprovalStatus" data-proj-name="@project.ProjName" style="padding: 1px !important;font-size: 13px !important;margin-top: 1px;">Fwd</button>

															}

														</div>

														@if (project.StageId == 1 && project.IsProcess == false && Convert.ToInt32(ViewBag.unitid) == 1 && project.IsCc == false)
														{
															<div class="col-md-4">
																<button type="button" class="btn btn-success btn-Obsn" data-proj-name="@project.ProjName" style="padding: 1px !important;font-size: 13px !important;">Obsn</button>
															</div>
														}
														<div class="mr-2">
															@if(project.IsCc == true)
															{

																<button type="button" class="btn btn-success invisible" style="padding: 1px !important;font-size: 13px !important;margin-top: 1px;">Fwd</button>


															}
														</div>
														<div class="col-md-4">
															<button type="button" class="btn btn-success btn-FwdHistory" data-proj-name="@project.ProjName" style="margin-top: 1px;" title="History"><i class="fa-solid fa-timeline"></i></button>
														</div>
													</div>
												</div>
											</td>
											<td>
												@*  @{
                                                    int currentUnitId = ViewBag.UnitId;
                                                } *@

												@*  @if (project.IsProcess == true && project.AdminApprovalStatus == true)
                                                {
                                                    <span title="Legacy Proj Granted by Admin">
                                                    <a href="#" class="date-action mr-2 disabled-link" data-action="current" data-ids="@project.EncyPsmID">
                                                        <img src="/assets/images/icons/Current_date.png" alt="Icon" style="height: 27px;">
                                                    </a>
                                                    </span>
                                                }
                                                else if (project.IsProcess == true && project.AdminApprovalStatus == false && project.UserRequest == true && project.RequestUnitId == currentUnitId)
                                                {
                                                    <!-- Pending shown only to the unit that requested -->
                                                    <span title="Request Pending with Admin">
                                                    <a href="#" class="date-action mr-2 disabled-link" data-action="Pending">
                                                        <img src="/assets/images/icons/Pendingbtn.png" alt="Icon" style="height: 30px;">
                                                    </a>
