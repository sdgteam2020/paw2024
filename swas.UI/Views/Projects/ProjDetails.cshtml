                                                        <img src="/assets/images/icons/Back_date.png" alt="Icon" style="height: 27px;">
                                                    </a>
                                                } *@
												@if (project.IsCc == false)
												{
													if (project.IsProcess == true && project.LatestActionType != null)
													{
														@if (project.IsProcess == true && project.LatestActionType == (int)ActionTypeEnum.Approved)
														{
															<span title="Approved Legacy Project">

																<a href="#" class="date-action mr-2 disabled-link" data-action="current" data-ids="@project.EncyPsmID">
																	<img src="/assets/images/icons/Current_date.png" alt="Icon" style="height: 27px;">
																</a>
															</span>
														}
														else if (project.IsProcess == true && project.LatestActionType == (int)ActionTypeEnum.RequestSent @* project.AdminApprovalStatus == false && project.UserRequest == true && project.RequestUnitId == currentUnitId *@)
														{
															<span title="Pending From Admin">
																<!-- Pending shown only to the unit that requested -->
																<a href="#" class="date-action mr-2 disabled-link" data-action="Pending">
																	<img src="/assets/images/icons/Pendingbtn.png" alt="Icon" style="height: 30px;">
																</a>
															</span>
														}
														else if (project.IsProcess == true && project.LatestActionType == (int)ActionTypeEnum.Rejected)
														{
															<!-- Other units can still request -->
															<a href="#" class="date-action mr-2" data-actiontype="1" data-action="back" data-ids="@project.EncyPsmID" title="Request for Back Date from Admin">
																<img src="/assets/images/icons/Back_date.png" alt="Icon" style="height: 27px;">
															</a>

														}

													}
													else
													{
														if (project.IsProcess == true && project.LatestActionType == null)
														{
															<!-- Other units can still request -->
