@using swas.DAL.Models
@model List<mRank>

@{
    ViewBag.Title = "Rank List";
}

<link href="~/css/rank_index.css" rel="stylesheet"/>

<button type="button" id="AddButon" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#UnitAdd" >
    Add New Rank
</button>

<div class="card radius-10 w-100">
    <div class="card-body">

        <table id="SoftwareType" class="table table-striped table-bordered">
            <!-- Table header -->
            <thead>
                <tr>
                    <th>Ser No</th>
                    <th>Rank Id</th>
                    <th>Rank Name</th>
                    <th>Delete</th>
                   
                </tr>
            </thead>

            <tbody>
                @foreach (var models in Model)
                {
                    <tr>
                        <td>@(Model.IndexOf(models) + 1)</td>
                        <td>@models.Id</td>
                        <td>@models.RankName</td>
                        <td>
                            <a data-id="@models.Id" data-url="@Url.Action("Index", "Rank")" class="btn btn-secondary btn-ecomm delete-btn"><i class='bx bx-trash'></i></a>
                        </td>
                    </tr>

                }

            </tbody>

        </table>

    </div>
</div>







<script src="~/js/sweetalert2.all.min.js"></script>


<div class="modal fade" id="UnitAdd" tabindex="-1" aria-labelledby="ProjectAddLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">

                <h5 class="text-center mb-4 underline-h5 new_rank">
                    <span>
                        New Rank Page
                    </span>
                </h5>
            </div>
            <div class="modal-body">

                @Html.Partial("_CreateRank", new mRank())


            </div>

        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    }


<script src="~/developerjs/rank.js"></script>