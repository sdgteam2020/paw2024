@using swas.BAL.DTO;
@using Microsoft.AspNetCore.Mvc.Rendering;
@using swas.DAL.Models;
@model tbl_Projects


<style>

    .header-container {
        background-color: #044c92; /* Change this to your preferred color */
        padding: 15px;
        text-align: center;
    }

    .h1 {
        font-size: 05px !important;
        font-color: #FFFFFF !important;
    }

</style>

<div class="accordion-body">
    <div class="row g-3">
        <!-- Upload Documents Card -->
        <div class="col-12 col-xl-6 d-flex">
            <div class="card radius-10 w-100">
                <div class="card-body">
                    <div class="header-container mb-3">
                        <h1 class="text-white fs-4">Please Upload Documents</h1>
                    </div>

                    <div class="row g-2">
                       @*  <div class="col-12 col-md-4">
                            <!-- Empty or custom content placeholder -->
                        </div> *@
                        <div class="col-12 col-md-4 mb-3">
                            <label for="Reamarks" class="form-label">ATT DOCU DESC</label>
                            <input type="text" class="form-control requiredField" id="Reamarks" placeholder="Enter document description" />
                            <div class="invalid-feedback">ATT DOCU DESC Required</div>
                        </div> <div class="col-12 col-md-4">
                            <!-- Empty or custom content placeholder -->
                        </div>

                        <div class="col-12 col-md-4">
                            <label for="pdfFileInput" class="form-label">Upload PDF file (Max size: 10MB)</label>
                            <input type="file" id="pdfFileInput" name="uploadfile" class="form-control requiredField" accept=".pdf">
                            <div class="invalid-feedback">Upload PDF file Required</div>
                        </div>
                        <div class="col-12 text-center mt-2">
                            <button type="button" id="uploadButton" class="btn btn-primary" formnovalidate>Upload Documents</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6 mb-3">
    <div class="card radius-10 w-100">
        <div class="card-body">
            <div class="header-container mb-3">
                <h1 class="text-white fs-4">Details of Uploaded Documents</h1>
            </div>

            <div class="table-responsive">
                <table id="SoftwareTypes" class="table table-striped table-bordered table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Delete</th>
                            <th>Docu Desc</th>
                            <th>File Name</th>
                            <th>Timestamp</th>
                        </tr>
                    </thead>
                    <tbody id="DetailBody">
                        <!-- Dynamically filled rows -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

    </div>
</div>
<script>

    const pdfFileInput = document.getElementById('pdfFileInput');

    pdfFileInput.addEventListener('change', function (event) {
        const file = event.target.files[0];

        if (file) {


            const maxSizeInBytes = 10 * 1024 * 1024;
            if (file.size > maxSizeInBytes) {

                pdfFileInput.value = '';
                Swal.fire({
                    title: 'File Size Exceeded',
                    text: 'Please select a file smaller than 10MB.',
                    icon: 'error',
                    confirmButtonText: 'OK'
                });
                return;
            }


            const reader = new FileReader();
            reader.onloadend = function () {
                const bytes = new Uint8Array(reader.result);
                const pdfHeader = new Uint8Array([37, 80, 68, 70, 45]); // %PDF-
                const isPDF = compareArrays(bytes.slice(0, 5), pdfHeader);
                if (isPDF) {

                    console.log('PDF file is valid. Proceed with upload.');
                } else {

                    Swal.fire({
                        title: 'Invalid File ....!',
                        text: 'Invalid PDF file. Please select a valid PDF file.',
                        icon: 'error',
                        confirmButtonText: 'OK'
                    });

                    pdfFileInput.value = '';
                }
            };


            reader.readAsArrayBuffer(file);
        }
    });


    function compareArrays(array1, array2) {
        if (array1.length !== array2.length) {
            return false;
        }
        for (let i = 0; i < array1.length; i++) {
            if (array1[i] !== array2[i]) {
                return false;
            }
        }
        return true;
    }
</script>