@using swas.BAL.DTO;
@using Microsoft.AspNetCore.Mvc.Rendering;
@using swas.DAL.Models;
@model tbl_Projects

<link href="~/css/_newprojfwdupload.css" rel="stylesheet" asp-append-version="true" />

<div class="accordion-body">
    <div class="row">

        <!-- Upload Section -->
        <div class="col-12 col-lg-12 col-xl-6 d-flex">
            <div class="card radius-10 w-100">
                <div class="card-body">

                    <div class="header-container">
                        <h1 class="fwdupload-title">Please Upload Docus</h1>
                    </div>

                    <table id="fwduploaditems" class="table table-striped table-bordered">
                        <tr>
                            <td></td>

                            <td>
                                ATT DOCU DESC
                                <input type="text" class="form-control requiredField" id="Reamarks" />
                                <div class="invalid-feedback">
                                    ATT DOCU DESC Required
                                </div>
                            </td>

                            <td colspan="2">
                                <p class="upload-note">Upload PDF file (Maximum size: 10MB)</p>
                                <input type="file"
                                       id="pdfFileInput"
                                       name="uploadfile"
                                       class="form-control-file requiredField"
                                       accept=".pdf" />
                                <div class="invalid-feedback">
                                    Upload PDF file Required
                                </div>
                            </td>
                        </tr>

                        <tr>
                            <td colspan="4" class="text-center">
                                <button type="button"
                                        id="uploadButton"
                                        class="btn btn-primary"
                                        formnovalidate>
                                    Upload Documents
                                </button>
                            </td>
                        </tr>
                    </table>

                </div>
            </div>
        </div>

        <!-- Uploaded Documents List -->
        <div class="col-12 col-xl-6 mb-3">
            <div class="card radius-10 w-100">
                <div class="card-body">

                    <div class="header-container mb-3">
                        <h1 class="fwdupload-title-secondary">
                            Details of Uploaded Documents
                        </h1>
                    </div>

                    <table id="SoftwareTypes"
                           class="table table-striped table-bordered table-hover">
                        <thead>
                            <tr>
                                <th>Delete</th>
                                <th>Docu Desc</th>
                                <th>File Name</th>
                                <th>Timestamp</th>
                            </tr>
                        </thead>
                        <tbody id="DetailBody">
                            <!-- Dynamically filled rows -->
                        </tbody>
                    </table>

                </div>
            </div>
        </div>

    </div>
</div>

<script src="~/DeveloperJs/_newprojfwdupload.js"></script>
