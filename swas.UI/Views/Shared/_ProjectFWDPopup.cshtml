<link href="~/css/_projectfwdpopup.css" rel="stylesheet" />

<div class="modal fade" id="ProjFwd" tabindex="-1" role="dialog"
	 data-bs-backdrop="static" data-bs-keyboard="false"
	 aria-labelledby="staticBackdropLabel" aria-hidden="true">
	<div class="modal-dialog modal-xl custom-modal-size">
		<div class="modal-content custom-modal-content projfwd-modal-content-w80">
			<div class="modal-header">
				<h5 class="modal-title" id="fwdModal">Project Fwd</h5>
				<span class="d-none" id="fwdprojid"></span>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>

			<div class="modal-body">
				<div class="row">
					<div class="col-md-12">
						<span class="d-none" id="spanCurrentPslmId">0</span>
						<span class="d-none" id="spanFwdCurrentPslmId">0</span>
						<span class="d-none" id="spanLegacyApproval">0</span>
						<span class="d-none" id="spanFwdProjectId">0</span>
						<span class="d-none" id="SpnFwdStakeHolderId">0</span>

						<div class="">
							<div class="row d-flex mb-2">

								<!-- Preview Summary -->
								<div class="col-md-6 Attmenthistory adjustsizeofdive d-none">
									<div class="shadow-sm border-0 rounded-4 overflow-hidden">
										<div class="card-header gradient-header text-white text-center py-3">
											<h6 class="mb-0 fw-bold">
												<i class="fas fa-eye me-2"></i>Preview Summary
											</h6>
										</div>

										<div class="card-body p-4 projfwd-preview-body-bg">
											<div id="previewGrid" class="row g-4"></div>

											<div class="mt-4 text-end">
												<button type="button" class="btn btn-outline-primary me-2" id="btnEditMove">
													<i class="fas fa-edit me-1"></i>Edit
												</button>
											</div>
										</div>
									</div>
								</div>

								<!-- Preview Certificate -->
								<div class="col-md-6 previewcertificateAttment d-none">
									<div class="shadow-sm border-0 rounded-4 overflow-hidden">
										<div class="card-header gradient-header text-white text-center py-3">
											<h6 class="mb-0 fw-bold">
												<i class="fas fa-eye me-2"></i>Preview Certificate
											</h6>
										</div>

										<div class="card-body p-4 projfwd-preview-body-bg">
											<div id="Certificatepreview" class="row g-4"></div>
										</div>
									</div>
								</div>

							</div>

							<div class="modal-header ProjectsFwd projfwd-header-h50">
								<h6 class="card-title mb-0">
									Pl select appropriate details before dispatch of project to next stakeholder
								</h6>
								<div class="form-group col-md-2 ProjectsFwd">
									<button type="button" class="btn btn-danger" id="btn-ibutton"
											title="For more info please click">
										<i class="fa fa-info-circle" aria-hidden="true"></i>
									</button>
								</div>
							</div>

							<div class="card-body">
								<div class="form-row">
									<div class="form-group col-md-6 ProjectsFwd FwdDropdown">
										<strong><label for="inputEmail4" class="bold-text">1. To</label></strong>
										<select class="form-control requiredField projfwd-w-100" tabindex="-1"
												name="fwdoffrs" required id="ddlfwdFwdTo">
											<option value="0">Select Fwd To</option>
										</select>
									</div>

									<div class="form-group col-md-4 ProjectsFwdUnit d-none">
										<strong><label for="SubStage" class="bold-text">1.1. Sent to Unit</label></strong>
										<select class="form-control UnitSearchBox js-example-basic-single projfwd-w-100"
												name="searchBox" id="searchBox" required>
											<option value="0">Select Fwd To</option>
										</select>
									</div>

									<div class="form-group col-md-4 ProjectsFwd d-none">
										<strong><label for="SubStage" class="bold-text">2. CC</label></strong>
										<select class="form-control is-invalid js-example-basic-multiple projfwd-w-100"
												multiple="multiple" name="fwdccoffrs" required id="ddlfwdCCTo">
											<option value="0">Select Fwd To</option>
										</select>
									</div>

									<div class="form-group col-md-6 ProjectsFwd">
										<strong><label for="inputEmail4" class="bold-text">3. Select Stage</label></strong>
										<select class="form-control requiredField projfwd-w-100"
												name="fwdoffrs" required id="ddlfwdStage">
											<option value="0">Select Stage</option>
										</select>
									</div>

									<div class="form-group col-md-6 ProjectsFwd">
										<strong><label for="SubStage" class="bold-text">4. Select Sub Stage</label></strong>
										<select class="form-control requiredField projfwd-w-100"
												name="fwdoffrs" required id="ddlfwdSubStage">
											<option value="0">Select Sub Stage</option>
										</select>
									</div>

									<div class="form-group col-md-6 ProjectsFwd">
										<strong><label for="SubStage" class="bold-text">5. Select Action</label></strong>
										<select class="form-control requiredField projfwd-w-100"
												name="fwdoffrs" required id="ddlfwdAction">
											<option value="0">Select Action</option>
										</select>
									</div>

									<div class="form-group col-md-6 ProjectsFwd">
										<strong><label for="SubStage" class="bold-text">6. Remarks</label></strong>
										<textarea class="form-control requiredField projfwd-remarks-w100" id="txtRemarksfwd"></textarea>
									</div>

									<div class="form-group col-md-4 ProjectsFwd">
										<strong><label class="bold-text">7. Date of Fwd:</label></strong>
										<input id="TimeStampToProjfwd" type="date" class="form-control requiredField projfwd-date-w200" />
									</div>

								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="col-md-12">
					<div class="">
						<div class="modal-header ProjectsFwd projfwd-header-neg-margins">
							<h6 class="card-title">Details of Att</h6>
						</div>

						<div class="row">
							<div class="form-group col-md-6 ProjectsFwd">
								<strong><label for="SubStage" class="bold-text">8. Upload Pdf File</label></strong>
								<input class="form-control requiredFieldAttch" type="file" id="pdfFileInput">
							</div>

							<div class="form-group col-md-6 ProjectsFwd">
								<strong><label for="SubStage" class="bold-text">9. Attach Document Description</label></strong>
								<textarea class="form-control requiredFieldAttch projfwd-remarks-w100" id="Reamarks"></textarea>
							</div>
						</div>

						<div class="form-group col-md-12 ProjectsFwd text-center">
							<button class="btn btn-warning" type="button" id="btnAttchMultiforpsmid">Upload File</button>
						</div>

						<div class="card-body projfwd-overflow-auto">
							<table class="table table-striped table-bordered">
								<thead>
									<tr>
										<th class="att-delete-col">Delete</th>
										<th>Docu Desc</th>
										<th>File Name</th>
										<th>Timestamp</th>
									</tr>
								</thead>
								<tbody id="AttBody"></tbody>
							</table>
						</div>
					</div>

					<div class="uploadLoader d-none projfwd-upload-overlay">
						<div class="d-flex justify-content-center align-items-center h-100">
							<div class="text-center">
								<div class="spinner-border text-success projfwd-spinner-lg" role="status">
									<span class="visually-hidden">Uploading...</span>
								</div>
								<div class="mt-3 text-white">Uploading, please wait...</div>
							</div>
						</div>
					</div>
				</div>

				<div class="form-group col-md-12 mt-4 d-flex justify-content-center gap-3 flex-wrap">
					<input type="button" id="btnFwdNext" value="Send"
						   class="btn btn-primary btn-lg ProjectsFwd" />

					<input type="button" id="btnlogsign" value="Digital Log & Send"
						   class="btn btn-primary btn-lg btnFwdConfirm btnhideenonfwd d-none" />

					<input type="button" id="btnconfirm" value="Confirm"
						   class="btn btn-primary btn-lg Attmenthistory d-none btnFwdConfirm" />

					<input type="button" id="btnDigitalsign" value="Digital Sign & Send"
						   class="btn btn-primary btn-lg btnhideenonfwd d-none" />
				</div>


			</div>
		</div>
	</div>
</div>

<div class="modal fade right" id="Projibutton" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-xl" role="document">
		<div class="modal-content">
			<div class="modal-header">
				<h4 class="modal-title" id="lblHistory">Project Fwd History</h4>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>

			<div class="modal-body">
				<img src="~/assets/images/flow.png" class="FlowImg" />
			</div>
		</div>
	</div>
</div>


@* <script src="~/DeveloperJs/FwdProject.js"></script> *@
@* <script src="~/DeveloperJs/AttHistory.js"></script> *@
<script src="~/DeveloperJs/Mtable.js"></script>