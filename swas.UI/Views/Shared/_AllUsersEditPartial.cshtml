@model InputModel
@using Microsoft.AspNetCore.Identity;
@using Newtonsoft.Json;
@using swas.BAL.Helpers
@using swas.BAL.Repository
@using swas.DAL
@using swas.DAL.Models
@using swas.BAL.Interfaces
@using swas.BAL.DTO
@inject IHttpContextAccessor HttpContextAccessor
@{

    // Layout = "~/Views/Shared/_Layout.cshtml";

    var roles = (List<Types>)ViewData["roles"];
    var iamuser = (List<AddlTask>)ViewData["IAMUser"];
    var units = (List<UnitDtl>)ViewData["Unit"];
    var typesList = ViewBag.Type;
    var Rank = (List<mRank>)ViewData["rank"];
    Login Logins = SessionHelper.GetObjectFromJson<Login>(HttpContextAccessor.HttpContext.Session, "User");
    bool isRestricted = Logins.unitid != 1;

    var Selectedtype = ViewBag.SelectedType;
    string selectedRoleName = ViewData["ty"]?.ToString() ?? "";
}


<form id="updateProfileFormPartial" method="post" action="@Url.Action("UpdateUserEdit", "Account")">
    <table class="table table-striped table-bordered">
        <tr>
            <td>
                <label asp-for="UserName" class="label control-label">Regn Id (UserName)</label>
            </td>
            <td>
                <input asp-for="UserName" class="form-control" onkeyup="ValInDataEdit(this)" maxlength="20" readonly/>
                <input hidden asp-for="Id" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </td>
        </tr>

        <tr>
            <td><label asp-for="RankId" class="label control-label">Select Rank</label></td>
            <td>
                <select asp-for="RankId" class="form-control dropdownsearch" asp-items="@(new SelectList((List<mRank>)ViewData["Rank"], "Id", "RankName", Model.RankId))">
                </select>

                <span asp-validation-for="RankId" class="text-danger"></span>
            </td>
        </tr>

        <tr>
            <td><label asp-for="OfficerName" class="label control-label">Name</label></td>
            <td>
                <input asp-for="OfficerName" class="form-control" />
                <span asp-validation-for="OfficerName" class="text-danger"></span>
            </td>
        </tr>

        <tr>
            <td><label asp-for="appointment" class="label control-label">Appointment</label></td>
            <td>
                <input asp-for="appointment" class="form-control" />
                <span asp-validation-for="appointment" class="text-danger"></span>
            </td>
        </tr>

        <tr>
            <td><label asp-for="Tele_Army" class="label control-label">Tele No (Army)</label></td>
            <td>
                <input asp-for="Tele_Army" class="form-control" />
                <span asp-validation-for="Tele_Army" class="text-danger"></span>
            </td>
        </tr>

        <tr>
            <td><label asp-for="unitId" class="label control-label">Select Unit</label></td>
            <td>
                <select asp-for="unitId" class="form-control dropdownsearch"
                        asp-items="@(new SelectList((List<UnitDtl>)ViewData["Unit"], "unitid", "UnitName", Model.unitId))">
                </select>

                <span asp-validation-for="unitId" class="text-danger"></span>
            </td>
        </tr>

        <tr>
            <td>
                <label asp-for="RoleName" class="label control-label">Select Role</label>
            </td>

            <td>
                <select asp-for="RoleName"
                        class="ms form-control inputs dropdownsearch"
                       disabled >
                    @foreach (var Role in typesList)
                    {
                        if (ViewData["ty"]?.ToString() == Role.Name)
                        {
                            <option selected value="@Role.Id">@Role.Name</option>
                           
                        }
                        else
                        {
                            <option value="@Role.Id">@Role.Name</option>
                        }
                    }
                </select>

                @{
                    int selectedRoleId = 0;
                    foreach (var role in Selectedtype)
                    {
                        if (role.Name == selectedRoleName)
                        {
                            selectedRoleId = role.Id;
                            break;
                        }
                    }
                }

                <input type="hidden" asp-for="RoleName" value="@selectedRoleId" />
                <span asp-validation-for="RoleName" class="text-danger"></span>
            </td>


          
        </tr>

        <tr>
            <td colspan="2" class="text-center">
                <button type="submit" class="btn btn-primary">Update</button>
            </td>
        </tr>
    </table>
</form>

<script>
    function ValInDataEdit(input) {
        var regex = /[^a-zA-Z0-9_]/g; // underscore allowed
        input.value = input.value.replace(regex, "");
    }



      

</script>
