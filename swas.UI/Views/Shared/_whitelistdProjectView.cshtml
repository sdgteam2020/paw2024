        margin-left: -2rem !important;
       
        height: auto; /* Remove fixed height to allow dynamic content */
    }
</style>
<link href="~/assets/css/tooltip.css" rel="stylesheet" />
<div class="modal fade bd-example-modal-xl" id="WhiteListedProjectDetail" tabindex="-1" role="dialog" aria-hidden="true" style="display: none;">
    <div class="modal-dialog modal-xl" style="max-width:95% !important">
        <div class="modal-content" style="width: 111rem !important;">
            <div class="modal-header">
                <h5 class="modal-title"><span class="spnWhitelistedorDues"></span></h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body WhitelistedTablesss p-0">
               
                    <table id="WhitelistedTable" class="table  table-striped table-bordered datatablefordownload" style="overflow: scroll;">
                        <!-- Table header -->
                    
                        <button class="btn btn-primary" id="AddWhite_proj">Add WhiteList</button>
                    
                        <thead style="position: sticky;top:-18px">

                            <tr>

                                <th class="text-center s-no-column" style="width:1%">S.No</th>
                                <th class="text-nowrap text-center" style="width:8% !important">Name of Sw Appl</th>
                                <th class="text-nowrap text-center" style="width:8% !important">Hosted On</th>

                                <th class="text-nowrap text-center" style="width:4% !important">Appt</th>
                                <th class="text-nowrap text-center" style="width:4% !important">Sponsor</th>
                                <th class="text-nowrap text-center" style="width:2% !important">Tele No</th>
                                <th class="text-nowrap text-center" style="width:6% !important">Dt of ACG Clearance</th>
                                <th class="text-nowrap text-center" style="width:15% !important">Cert No</th>
                                <th class="text-nowrap text-center" style="width:4% !important">Valid Upto</th>
                                <th class="text-nowrap text-center" style="width:4% !important">Remarks</th>


                            </tr>
                        </thead>
                        <tbody id="WhitelistedTableData">
                        </tbody>
                    </table>


               
            
            </div>
        </div>
    </div>
</div>

<div class="modal fade bd-example-modal-xl" id="WhiteListModal" tabindex="-1" role="dialog" aria-hidden="true" style="display: none;">

    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add to WhiteList</h5>
                <button type="button" class="btn-close" onclick="cancelModal(this);" data-bs-dismiss="modal"></button>
            </div>


            <div class="modal-body">
                <form id="WhiteListForm">

                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <label for="swName" class="form-label">
                                Name of SW Appl<span class="required-star">*</span>
                            </label>
                            <input type="text" class="form-control" id="swName" name="swName" required placeholder="Enter Software/Application Name" />

                            <div class="invalid-feedback" style="color:red">This field is required.</div>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label for="hostedOn" class="form-label">Hosted On<span class="required-star">*</span></label>
                            <select class="form-control" id="hostedOn" name="hostedOn" required>
                               
                               
                            </select>
                            <div class="invalid-feedback" style="color:red">This field is required.</div>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label for="appt" class="form-label">Appt<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="appt" name="appt" required placeholder="Enter Appointment" />
                            <div class="invalid-feedback" style="color:red">This field is required.</div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <label for="sponsor" class="form-label">Sponsor (Unit)<span class="required-star">*</span></label>
                            <select class="form-control" id="sponsor" name="sponsor" required>
                               
                               
                            </select>
                            <div class="invalid-feedback" style="color:red">This field is required.</div>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label for="telNo" class="form-label">Tele No<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="telNo" name="telNo" required placeholder="Enter Telephone Number" />
                            <div class="invalid-feedback" style="color:red">This field is required.</div>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label for="clearanceDate" class="form-label">Dt of ACG Clearance<span class="required-star">*</span></label>
                            <input type="date" class="form-control" id="clearanceDate" name="clearanceDate" required placeholder="Select Clearance Date" />
                            <div class="invalid-feedback" style="color:red">This field is required.</div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <label for="certNo" class="form-label">Cert No<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="certNo" name="certNo" required placeholder="Enter Certificate Number" />
                            <div class="invalid-feedback" style="color:red">This field is required.</div>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label for="validUpto" class="form-label">DDGIT WL Date<span class="required-star">*</span></label>
                            <input type="date" class="form-control" id="validUpto" name="validUpto" required placeholder="Select Valid Upto Date" />
                            <div class="invalid-feedback" style="color:red">This field is required.</div>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label for="remarks" class="form-label">Remarks<span class="required-star">*</span></label>
                            <textarea class="form-control" id="remarks" name="remarks" required placeholder="Enter Remarks"></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" id="btn_Save">Save</button>
                    <button type="button" class="btn btn-secondary" onclick="cancelModal(this);" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success d-none" id="btnDummyData">dummy data</button>



                </form>
            </div>
        </div>
    </div>
</div>

<script src="~/developerjs/commandatatable.js"></script>
<script src="~/developerjs/tooltip.js"></script>
<script src="~/developerjs/whitelistedpartialview.js"></script>