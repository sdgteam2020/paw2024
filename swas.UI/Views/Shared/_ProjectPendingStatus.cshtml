<link href="~/css/_projectpendingstatus.css" rel="stylesheet" />
 
<div class="modal fade" id="ProjHoldHistory" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">

                <h4 class="modal-title" id="">Name of Project : <span class="lblProjHoldHistory"></span> </h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="card-body">
                <div class="card radius-10 w-100">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered  tblProjectWiseStatusByprojid">
                            </table>

                        </div>
                      

                    </div>
                </div>
            </div>

            <div class="modal-body">
                <div class="card d-none1" id="cardforProjHoldHistory">
                    <div class="dashboard">
                        <!-- Years Wise Status -->
                        <div>
                            <div class="header-container text-center text-white"> Pendency Status : Serial Movement of Proj  </div>
                            <div class="chart-box">

                                <canvas id="ProjHoldHistoryChart"></canvas>
                            </div>
                        </div>
                        <div>
                            <div class="header-container text-center text-white">Pendency Status : Simultaneous Comments of Stakeholders </div>
                            <div class="chart-box">

                                <canvas id="ProjHoldHistoryCommentChart"></canvas>
                            </div>
                        </div>



                    </div>
                </div> <div class="header-container text-center text-white mt-4"> Pendency Status : Serial Movement of Proj  </div>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered" id="tblprojhold">


                        <thead>
                            <tr>


                                <th class="nowrap">Ser. No</th>
                                <th class="nowrap">From Unit</th>
                                <th class="nowrap">To Unit</th>
                                <th class="nowrap">Sub Stage</th>
                                <th class="nowrap">Action</th>
                                <th class="nowrap">Received On</th>
                                <th class="nowrap">Accepted On</th>
                                <th class="nowrap">Total Days (hh:mm)</th>

                            </tr>
                        </thead>
                        <tbody id="DetailBodyhold">
                        </tbody>
                    </table>

                </div>
             
                 
                <div class="header-container text-center text-white">Pendency Status of Simultaneous Comments by Stakeholders  <span id="Recddt"></span></div>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered" id="tblprojComments">

                        <thead>
                            <tr>


                                <th class="nowrap">Ser. No</th>
                                 
                                <th class="nowrap">To Unit</th>
                                <th class="nowrap">Sub Stage</th>
                                 
                                 
                                <th class="nowrap">Latest Action</th>
                                <th class="nowrap">Latest Action Dt</th>
                                <th class="nowrap">Total Days (hh:mm)</th>
                                <th class="nowrap">Approved On/Reject On </th>

                            </tr>
                        </thead>
                        <tbody id="DetailBodyholdComments">
                        </tbody>
                    </table>
                </div>

                </div>

        </div><!-- modal-content -->
    </div><!-- modal-dialog -->
</div>
