<script>

    document.getElementById('menusharp').onclick = function () {
        document.body.classList.toggle('sidebar-collapsed');
    };

    document.querySelector('.sidebar-wrapper').onmouseenter = function () {
        document.body.classList.add('sidebar-hover');
    };

    document.querySelector('.sidebar-wrapper').onmouseleave = function () {
        document.body.classList.remove('sidebar-hover');
    };

</script>

<script>
  
        let hideTimeout;

    $('.dropdown').hover(
        function () {
            // On hover in: clear any pending hide and show dropdown
            clearTimeout(hideTimeout);
            $(this).children('.dropdown-menu').stop(true, true).slideDown(200);
        },
        function () {
            // On hover out: delay hide to prevent flicker
            const $menu = $(this).children('.dropdown-menu');
            hideTimeout = setTimeout(function () {
                $menu.stop(true, true).slideUp(200);
            }, 200   ); // You can adjust this delay as needed
        }
    );
</script>

<script>
    $(document).ready(function () {

        var currentPageUrl = window.location.pathname;


        $(".dropdown-menu li").removeClass("selected");


        $(".dropdown-menu li a[href='" + currentPageUrl + "']").parent().addClass("selected");


        $(".dropdown-menu.selected").addClass("visible");
    });
</script>
<script>
    $(document).ready(function () {
        var claValue = @Logins?.cla; // Get the value of Logins.cla

        if (claValue == 2) {
            $('#fromDate').attr('type', 'date').removeAttr('max').removeAttr('min');
            $('#toDate').attr('type', 'date').removeAttr('max').removeAttr('min');
        } else {
            $('#fromDate').attr('type', 'date').removeAttr('max').removeAttr('min');
            $('#toDate').attr('type', 'date').removeAttr('max').removeAttr('min');
        }
    });

</script>

<script>
    function ValInData(input) {

        var regex = /[^a-zA-Z0-9 ]/g;
